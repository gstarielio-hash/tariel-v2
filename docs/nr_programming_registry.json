  "implementation_standard": {
    "policy_name": "nr_family_hardening_from_official_basis",
    "policy_version": 1,
    "summary": "Toda implementacao ou endurecimento de familia NR deve partir de pesquisa em fonte oficial vigente e registrar claramente o que e requisito normativo versus decisao editorial do template.",
    "source_priority": [
      "Texto oficial da NR vigente no portal gov.br do Ministerio do Trabalho e Emprego",
      "Manuais oficiais de interpretacao, guias tecnicos e materiais oficiais publicados em gov.br/Fundacentro/MTE",
      "Normas tecnicas e anexos expressamente citados pela NR, quando houver acesso oficial ou licenciado"
    ],
    "required_schema_metadata": [
      "normative_basis"
    ],
    "rules": [
      "Nao deduzir requisito obrigatorio sem ancora em fonte oficial pesquisada",
      "Separar no schema a base normativa da estrutura editorial do documento",
      "Quando a NR remeter a norma tecnica externa indisponivel, registrar a remissao sem inventar clausulas nao acessadas",
      "Ao tocar uma familia existente, retrofitar sua base normativa oficial no mesmo pacote",
      "Mudanca detectada em fonte oficial nao autoriza atualizacao automatica de template; o fluxo padrao e diff tecnico com revisao manual do admin/CEO"
    ]
  },
