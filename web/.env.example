# Ambiente e aplicação
AMBIENTE=dev
PORTA=8000
APP_VERSAO=2.0-SaaS
APP_BUILD_ID=dev
APP_HOST_PUBLICO=127.0.0.1:8000
ALLOWED_HOSTS=localhost,127.0.0.1,::1,testserver
CHAVE_SECRETA_APP=troque-por-uma-chave-com-no-minimo-32-caracteres
SESSION_COOKIE_NAME=cracha_tariel_seguro
SESSION_MAX_AGE=2592000
REDIS_URL=redis://127.0.0.1:6379/0
REVISOR_REALTIME_BACKEND=redis
REVISOR_REALTIME_FAIL_CLOSED_ON_STARTUP=1
REVISOR_REALTIME_CHANNEL_PREFIX=tariel:revisor
PASTA_UPLOADS_PERFIS=static/uploads/perfis
PASTA_ANEXOS_MESA=
PASTA_APRENDIZADOS_VISUAIS_IA=static/uploads/aprendizados_ia
TARIEL_UPLOADS_STORAGE_MODE=local_fs
TARIEL_UPLOADS_PROFILE_RETENTION_DAYS=365
TARIEL_UPLOADS_MESA_RETENTION_DAYS=365
TARIEL_UPLOADS_LEARNING_RETENTION_DAYS=365
TARIEL_UPLOADS_CLEANUP_ENABLED=1
TARIEL_UPLOADS_CLEANUP_GRACE_DAYS=14
TARIEL_UPLOADS_CLEANUP_INTERVAL_HOURS=24
TARIEL_UPLOADS_CLEANUP_MAX_DELETIONS_PER_RUN=200
TARIEL_UPLOADS_BACKUP_REQUIRED=0
TARIEL_UPLOADS_RESTORE_DRILL_REQUIRED=0

# Observabilidade e segurança operacional
OBSERVABILITY_HEADER_NAME=X-Correlation-ID
OBSERVABILITY_CLIENT_REQUEST_HEADER_NAME=X-Client-Request-Id
OBSERVABILITY_TRACE_HEADER_NAME=X-Trace-Id
OBSERVABILITY_RELEASE=2.0-SaaS
OBSERVABILITY_LOG_RETENTION_DAYS=14
OBSERVABILITY_PERF_RETENTION_DAYS=7
OBSERVABILITY_ARTIFACT_RETENTION_DAYS=7
OTEL_ENABLED=0
OTEL_SERVICE_NAME=tariel-web
OTEL_SERVICE_NAMESPACE=tariel
OTEL_EXPORTER_MODE=console
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORT_TIMEOUT_MS=5000
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=0
TARIEL_BROWSER_ANALYTICS_ENABLED=0
TARIEL_BROWSER_REPLAY_ENABLED=0
TARIEL_MOBILE_ANALYTICS_OPT_IN_REQUIRED=1

# Banco de dados
# Stack local madura: PostgreSQL via socket Unix/peer auth no banco tariel_dev.
DATABASE_URL=postgresql:///tariel_dev
DB_SQLALCHEMY_DRIVER=psycopg
DB_SSLMODE=
DB_CONNECT_TIMEOUT=0
DB_APPLICATION_NAME=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_BOOTSTRAP_RUN_MIGRATIONS=1
DB_BOOTSTRAP_BLOCKING_STARTUP=1
DB_BOOTSTRAP_MAX_ATTEMPTS=8
DB_BOOTSTRAP_RETRY_BASE_SECONDS=2
DB_BOOTSTRAP_RETRY_MAX_SECONDS=15
DB_BOOTSTRAP_BACKGROUND_RETRY_BASE_SECONDS=15
DB_BOOTSTRAP_BACKGROUND_RETRY_MAX_SECONDS=60

# Segurança de sessão
BCRYPT_ROUNDS=12
SESSAO_TTL_HORAS=8
SESSAO_TTL_LEMBRAR_DIAS=30
SESSAO_MAX_POR_USUARIO=5
SESSAO_JANELA_RENOVACAO_MINUTOS=30
SESSAO_CHANCE_LIMPEZA=100
SESSAO_CACHE_DB_REVALIDACAO_SEGUNDOS=0
SESSAO_FAIL_CLOSED_ON_DB_ERROR=0
SESSAO_VINCULAR_USER_AGENT=0
SESSAO_VINCULAR_IP=0
SESSAO_RENOVACAO_ATIVA=1

# IA e OCR (obrigatório para recursos de IA)
# Use um arquivo local não-versionado para as credenciais da Vision.
CHAVE_API_GEMINI=coloque_sua_chave
GEMINI_MODELO=gemini-2.5-flash
GEMINI_CUSTO_INPUT_USD=0.000000075
GEMINI_CUSTO_OUTPUT_USD=0.0000003
TAXA_CAMBIO_USD_BRL=5.80
GOOGLE_APPLICATION_CREDENTIALS=visao_tariel.local.json

# Seeds opcionais para bootstrap
SEED_DEV_BOOTSTRAP=0
SEED_DEV_SENHA_PADRAO=Dev@123456
SEED_ADMIN_SENHA=
SEED_REVISOR_SENHA=
SEED_INSPETOR_SENHA=

# Bootstrap inicial de produção (primeiro Admin-CEO em banco vazio)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NOME=Administrador Tariel.ia
BOOTSTRAP_EMPRESA_NOME=Tariel.ia
BOOTSTRAP_EMPRESA_CNPJ=11111111111111
ADMIN_WELCOME_NOTIFICATION_BACKEND=log

# Interface
SUPORTE_WHATSAPP=5516999999999
DIR_PDF_LAUDOS=

