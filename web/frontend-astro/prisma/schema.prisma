  referencias_norma_json                                     Json             @db.Json
  marcacoes_json                                             Json             @db.Json
  status                                                     String           @db.VarChar(17)
  veredito_inspetor                                          String           @db.VarChar(12)
  veredito_mesa                                              String?          @db.VarChar(12)
  imagem_url                                                 String?          @db.VarChar(600)
  imagem_nome_original                                       String?          @db.VarChar(160)
  imagem_mime_type                                           String?          @db.VarChar(120)
  imagem_sha256                                              String?          @db.VarChar(64)
  caminho_arquivo                                            String?          @db.VarChar(600)
  validado_em                                                DateTime?        @db.Timestamptz(6)
  criado_em                                                  DateTime         @db.Timestamptz(6)
  atualizado_em                                              DateTime?        @db.Timestamptz(6)
