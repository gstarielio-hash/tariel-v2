  empresas                                                   empresas         @relation(fields: [empresa_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  laudos                                                     laudos           @relation(fields: [laudo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  mensagens_laudo                                            mensagens_laudo? @relation(fields: [mensagem_referencia_id], references: [id], onUpdate: NoAction)
  usuarios_aprendizados_visuais_ia_validado_por_idTousuarios usuarios?        @relation("aprendizados_visuais_ia_validado_por_idTousuarios", fields: [validado_por_id], references: [id], onUpdate: NoAction)

  @@index([empresa_id, status, validado_em], map: "ix_aprendizado_visual_empresa_status")
  @@index([laudo_id, criado_em], map: "ix_aprendizado_visual_laudo_criado")
  @@index([mensagem_referencia_id], map: "ix_aprendizado_visual_ref_msg")
  @@index([empresa_id, setor_industrial, status], map: "ix_aprendizado_visual_setor_status")
  @@index([imagem_sha256], map: "ix_aprendizado_visual_sha")
  @@index([criado_por_id], map: "ix_aprendizados_visuais_ia_criado_por_id")
  @@index([empresa_id], map: "ix_aprendizados_visuais_ia_empresa_id")
  @@index([id], map: "ix_aprendizados_visuais_ia_id")
  @@index([laudo_id], map: "ix_aprendizados_visuais_ia_laudo_id")
  @@index([mensagem_referencia_id], map: "ix_aprendizados_visuais_ia_mensagem_referencia_id")
  @@index([validado_por_id], map: "ix_aprendizados_visuais_ia_validado_por_id")
}

