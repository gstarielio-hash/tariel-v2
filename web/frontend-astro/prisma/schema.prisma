generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model anexos_mesa {
  id              Int             @id @default(autoincrement())
  laudo_id        Int
  mensagem_id     Int
  enviado_por_id  Int?
  nome_original   String          @db.VarChar(160)
  nome_arquivo    String          @db.VarChar(220)
  mime_type       String          @db.VarChar(120)
  categoria       String          @db.VarChar(20)
  tamanho_bytes   Int
  caminho_arquivo String          @db.VarChar(600)
  criado_em       DateTime        @db.Timestamptz(6)
  usuarios        usuarios?       @relation(fields: [enviado_por_id], references: [id], onUpdate: NoAction)
  laudos          laudos          @relation(fields: [laudo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  mensagens_laudo mensagens_laudo @relation(fields: [mensagem_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([enviado_por_id], map: "ix_anexo_mesa_enviado_por")
  @@index([laudo_id, criado_em], map: "ix_anexo_mesa_laudo_criado")
  @@index([mensagem_id], map: "ix_anexo_mesa_mensagem")
  @@index([id], map: "ix_anexos_mesa_id")
  @@index([laudo_id], map: "ix_anexos_mesa_laudo_id")
  @@index([mensagem_id], map: "ix_anexos_mesa_mensagem_id")
}

model aprendizados_visuais_ia {
  id                                                         Int              @id @default(autoincrement())
  empresa_id                                                 Int
  laudo_id                                                   Int
  mensagem_referencia_id                                     Int?
  criado_por_id                                              Int?
  validado_por_id                                            Int?
