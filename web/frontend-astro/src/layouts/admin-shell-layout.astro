---
import {
  Boxes,
  Building2,
  FileSearch,
  LayoutDashboard,
  LogOut,
  PlusCircle,
  Settings2,
  ShieldEllipsis,
} from "lucide-react";

import StudioLayout from "@/layouts/studio-layout.astro";

interface Props {
  title?: string;
  description?: string;
  userName?: string;
  activeItem?: "dashboard" | "clients" | "catalog";
}

const {
  title = "Admin-CEO | Tariel Astro",
  description = "Painel administrativo migrado para Astro SSR com Prisma.",
  userName = "Admin-CEO",
  activeItem = "dashboard",
} = Astro.props;

const menuItems = [
  {
    href: "/admin/painel",
    label: "Visao geral",
    icon: LayoutDashboard,
    current: activeItem === "dashboard",
  },
  {
    href: "/admin/clientes",
    label: "Empresas",
    icon: Building2,
    current: activeItem === "clients",
  },
  {
    href: "/admin/catalogo-laudos",
    label: "Catalogo",
    icon: Boxes,
    current: activeItem === "catalog",
  },
  {
    href: "#operacao",
    label: "Operacao",
    icon: FileSearch,
  },
  {
    href: "#proxima-fatia",
    label: "Proxima fatia",
    icon: PlusCircle,
  },
  {
    href: "#seguranca",
    label: "Seguranca",
    icon: ShieldEllipsis,
  },
  {
    href: "/admin/login",
    label: "Tela de login",
    icon: Settings2,
  },
];
---

<StudioLayout title={title} description={description}>
  <main class="min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(249,115,22,0.14),transparent_28%),radial-gradient(circle_at_90%_0%,rgba(15,23,42,0.08),transparent_24%)] px-4 py-4 sm:px-6 sm:py-6">
    <div class="mx-auto grid min-h-[calc(100vh-2rem)] max-w-[1600px] overflow-hidden rounded-[34px] border border-slate-950/10 bg-white/78 shadow-[0_24px_120px_rgba(15,23,42,0.12)] backdrop-blur lg:grid-cols-[280px_minmax(0,1fr)]">
      <aside class="border-b border-slate-950/8 bg-slate-950 px-6 py-8 text-white lg:border-b-0 lg:border-r">
        <div class="rounded-[28px] border border-white/10 bg-white/6 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.26em] text-orange-200">Tariel Astro</p>
          <h1 class="mt-3 font-display text-3xl tracking-tight">Admin-CEO</h1>
          <p class="mt-3 text-sm leading-6 text-slate-300">
            Camada administrativa em migração progressiva do legado FastAPI para Astro SSR com Prisma.
          </p>
        </div>

        <nav class="mt-8 space-y-2" aria-label="Menu administrativo">
          {menuItems.map(({ href, label, icon: Icon, current }) => (
            <a
              href={href}
              class:list={[
                "flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition",
                current
                  ? "bg-white text-slate-950 shadow-[0_12px_30px_rgba(255,255,255,0.12)]"
                  : "text-slate-300 hover:bg-white/8 hover:text-white",
              ]}
              aria-current={current ? "page" : undefined}
            >
              <Icon className="size-4" />
              <span>{label}</span>
            </a>
          ))}
        </nav>

        <div id="seguranca" class="mt-8 rounded-[28px] border border-white/10 bg-white/6 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-orange-200">Seguranca</p>
          <p class="mt-3 text-sm leading-6 text-slate-300">
            Login, sessao e MFA ficam desacoplados do layout nesta fase para permitir a migracao por partes.
          </p>
        </div>

        <div class="mt-8 flex items-center justify-between rounded-[28px] border border-white/10 bg-white/6 p-5">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Usuario</p>
            <p class="mt-2 font-medium text-white">{userName}</p>
          </div>

          <a
            href="/admin/login"
            class="inline-flex items-center gap-2 rounded-full border border-white/12 px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-200 transition hover:border-white/28 hover:bg-white/8"
          >
            <LogOut className="size-4" />
            Sair
          </a>
        </div>
      </aside>

      <section class="min-w-0">
        <div class="border-b border-slate-950/8 px-6 py-6 sm:px-8">
          <slot name="header" />
        </div>

        <div class="px-6 py-6 sm:px-8 sm:py-8">
          <slot />
        </div>
      </section>
    </div>
  </main>
</StudioLayout>
