                        <div class="rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm leading-6 text-slate-600">
                          {selectedPackage.officialIssue.blockerCount} blockers • pronta para emissao:{" "}
                          {selectedPackage.officialIssue.readyForIssue ? "sim" : "nao"}
                        </div>
                      ) : null}
                    </div>
                  </div>

                  <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Revisoes recentes</p>
                    <div class="mt-4 space-y-2">
                      {selectedPackage.recentReviews.length > 0 ? selectedPackage.recentReviews.map((review) => (
                        <div class="rounded-2xl border border-slate-200 bg-white px-3 py-3 text-sm text-slate-700">
                          <div class="flex items-center justify-between gap-4">
                            <p class="font-semibold text-slate-950">Versao {review.version}</p>
                            <span class="text-xs uppercase tracking-[0.18em] text-slate-500">{review.createdAtLabel}</span>
                          </div>
                          <p class="mt-2 leading-6">
                            {review.summary ?? `${review.origin} • ${review.confidenceLabel ?? "sem confianca registrada"}`}
                          </p>
                        </div>
                      )) : (
                        <div class="rounded-2xl border border-dashed border-slate-300 bg-white px-3 py-4 text-sm leading-6 text-slate-600">
                          Nenhuma revisao recente registrada no pacote.
                        </div>
                      )}
                    </div>
                  </div>

                  {selectedPackage.aiSummary ? (
                    <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Parecer IA</p>
                      <p class="mt-3 whitespace-pre-wrap text-sm leading-6 text-slate-700">{selectedPackage.aiSummary}</p>
                    </div>
                  ) : null}
                </div>
              </div>
            </article>
          </>
        ) : (
          <article class="rounded-[32px] border border-dashed border-slate-300 bg-white p-10 text-center shadow-[0_18px_40px_rgba(15,23,42,0.04)]">
            <div class="mx-auto flex max-w-md flex-col items-center">
              <div class="rounded-3xl bg-sky-500/10 p-4 text-sky-700">
                <MessageSquare className="size-8" />
              </div>
              <h2 class="mt-6 font-display text-3xl tracking-tight text-slate-950">Selecione um laudo da fila</h2>
              <p class="mt-4 text-sm leading-7 text-slate-600">
                A thread, as pendencias e as decisoes aparecem aqui assim que um caso da lista for escolhido.
              </p>
            </div>
          </article>
        )}
      </div>
    </section>
  )}
</ClientShellLayout>
