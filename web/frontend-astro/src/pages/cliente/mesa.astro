---
import { ArrowRight, FileStack, LockKeyhole, ShieldCheck, Users } from "lucide-react";

import ClientShellLayout from "@/layouts/client-shell-layout.astro";
import { getClientPortalMesaData } from "@/lib/server/client-portal";

export const prerender = false;

const clientSession = Astro.locals.clientSession;

if (!clientSession) {
  return Astro.redirect("/cliente/login", 303);
}

const mesa = await getClientPortalMesaData(clientSession);

if (!mesa) {
  throw new Error("Empresa do portal cliente nao encontrada.");
}

const dateTimeFormatter = new Intl.DateTimeFormat("pt-BR", {
  dateStyle: "short",
  timeStyle: "short",
});

const summaryCards = [
  {
    label: "Equipe de analise",
    value: mesa.summary.reviewers,
    detail:
      mesa.summary.reviewers > 0
        ? `${mesa.summary.reviewers} revisores provisionados para a empresa.`
        : "Nenhum revisor provisionado ainda no tenant.",
    icon: Users,
  },
  {
    label: "Sessoes da mesa",
    value: mesa.summary.reviewerSessions,
    detail: "Revisores com atividade recente no tenant.",
    icon: ShieldCheck,
  },
  {
    label: "Aguardando avaliacao",
    value: mesa.summary.waitingReview,
    detail: "Laudos do tenant atualmente na fila de revisao.",
    icon: FileStack,
  },
  {
    label: "Primeiro acesso",
    value: mesa.summary.reviewerFirstAccessPending,
    detail: "Contas de revisao que ainda precisam trocar a senha inicial.",
    icon: LockKeyhole,
  },
];

const queueCards = [
  {
    label: "Rascunhos",
    value: mesa.summary.drafts,
    tone: "neutral",
  },
  {
    label: "Aguardando avaliacao",
    value: mesa.summary.waitingReview,
    tone: "warning",
  },
  {
    label: "Aprovados",
    value: mesa.summary.approved,
    tone: "success",
  },
  {
    label: "Rejeitados",
    value: mesa.summary.rejected,
    tone: "danger",
  },
] as const;
---

<ClientShellLayout
  title={`Mesa | ${mesa.detail.companyName} | Tariel Astro`}
  description="Snapshot governado da mesa do cliente no portal Astro."
  userName={clientSession.user.name}
  companyName={mesa.detail.companyName}
  activeItem="mesa"
>
  <Fragment slot="header">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-600">Mesa do cliente</p>
        <h1 class="mt-3 font-display text-3xl tracking-tight text-slate-950 sm:text-4xl">
          Snapshot governado da analise no V2
        </h1>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600">
          Este slice faz o portal cliente consumir a fila da mesa por um contrato explicito do backend Python. A
          interface e o shell seguem no Astro, mas o estado operacional agora vem governado pelos dominios `mesa` e
          `revisor`.
        </p>
      </div>

      <div class="rounded-[28px] border border-sky-500/16 bg-sky-500/6 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-700">Estado atual</p>
        <p class="mt-2 text-lg font-semibold text-slate-950">{mesa.detail.healthLabel}</p>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          {mesa.summary.waitingReview} casos aguardando avaliacao, {mesa.queue.pendingWhispers} whispers pendentes e{" "}
          {mesa.queue.openPendencies} pendencias abertas no recorte atual.
        </p>
      </div>
    </div>
  </Fragment>

  <section class="grid gap-4 xl:grid-cols-4">
    {summaryCards.map(({ label, value, detail, icon: Icon }) => (
      <article class="rounded-[30px] border border-slate-950/8 bg-white p-5 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{label}</p>
          <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
            <Icon className="size-5" />
          </div>
        </div>
        <p class="mt-5 font-display text-3xl tracking-tight text-slate-950">{value}</p>
        <p class="mt-3 text-sm leading-6 text-slate-600">{detail}</p>
      </article>
    ))}
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[0.92fr_1.08fr]">
    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Cobertura do slice</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">O que ja esta fechado</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          Slice 2
        </div>
      </div>

      <div class="mt-6 grid gap-3">
        <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
          <p class="text-sm font-semibold text-slate-950">Sessao oficial do portal cliente</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            O Astro segue usando a sessao real do admin-cliente para autenticar a leitura do snapshot Python sem
            depender do shell historico.
          </p>
        </div>

        <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
          <p class="text-sm font-semibold text-slate-950">Contrato governado</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Fila, auditoria e resumo de revisores agora chegam por um contrato explicito do backend Python, sem o
            frontend inferir a mesa direto do banco.
          </p>
        </div>

        <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-950">Proxima camada</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            O proximo slice liga mutacoes da mesa sobre este mesmo boundary sem abrir `/revisao` completo nem o
            `Inspetor` pesado.
          </p>
        </div>
      </div>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a
          href="/cliente/equipe"
          class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(15,23,42,0.18)] transition hover:bg-slate-800"
        >
          Gerir revisores
          <ArrowRight className="size-4" />
        </a>

        <a
          href="/revisao/login"
          class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50"
        >
          Abrir login da mesa
          <ArrowRight className="size-4" />
        </a>
      </div>
    </article>

    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Fila do tenant</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Distribuicao por status</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {mesa.detail.totalReports} laudos
        </div>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        {queueCards.map((card) => (
          <div
            class:list={[
              "rounded-[24px] border px-4 py-4",
              card.tone === "success" && "border-emerald-200 bg-emerald-50",
              card.tone === "warning" && "border-amber-200 bg-amber-50",
              card.tone === "danger" && "border-red-200 bg-red-50",
              card.tone === "neutral" && "border-slate-200 bg-slate-50",
            ]}
          >
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">{card.label}</p>
            <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">{card.value}</p>
          </div>
        ))}
      </div>

      {mesa.summary.otherStatuses > 0 ? (
        <div class="mt-4 rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-600">
          Existem {mesa.summary.otherStatuses} laudos em estados adicionais fora do recorte principal da fila.
        </div>
      ) : null}
    </article>
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[1.04fr_0.96fr]">
    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Fila governada</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Casos mais recentes do snapshot</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          Python owner
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {mesa.recentCases.length > 0 ? mesa.recentCases.map((report) => (
          <article class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="font-semibold text-slate-950">{report.sector || `Laudo ${report.hashShort}`}</p>
                <p class="mt-1 text-sm leading-6 text-slate-600">
                  {report.title} • {report.operationLabel} • inspetor {report.inspectorName}
                </p>
                <p class="mt-1 text-sm leading-6 text-slate-500">
                  {report.whispersPending} whispers • {report.openPendencies} pendencias • {report.pendingLearning}{" "}
                  aprendizados pendentes
                </p>
              </div>

              <div class="flex flex-col items-start gap-2 sm:items-end">
                <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
                  {report.statusVisualLabel}
                </span>
                <p class="text-sm text-slate-500">{report.updatedAt ? dateTimeFormatter.format(report.updatedAt) : report.updatedAtLabel}</p>
              </div>
            </div>
          </article>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Nenhum laudo recente foi encontrado para a mesa deste tenant.
          </div>
        )}
      </div>
    </article>

    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Equipe de revisao</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Pessoas habilitadas para a mesa</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {mesa.summary.reviewers} revisores
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {mesa.reviewers.length > 0 ? mesa.reviewers.map((reviewer) => (
          <article class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="font-semibold text-slate-950">{reviewer.name}</p>
                <p class="mt-1 text-sm leading-6 text-slate-600">
                  {reviewer.email} • {reviewer.portalLabel}
                </p>
              </div>

              <div class="flex flex-col items-start gap-2 sm:items-end">
                {reviewer.temporaryPasswordActive ? (
                  <span class="rounded-full border border-amber-200 bg-amber-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-800">
                    Primeiro acesso pendente
                  </span>
                ) : reviewer.blocked ? (
                  <span class="rounded-full border border-red-200 bg-red-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-red-800">
                    Bloqueado
                  </span>
                ) : (
                  <span class="rounded-full border border-emerald-200 bg-emerald-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-emerald-800">
                    Ativo
                  </span>
                )}
                <p class="text-sm text-slate-500">{reviewer.lastActivityLabel}</p>
              </div>
            </div>
          </article>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Nenhuma pessoa da mesa foi provisionada ainda. Use a tela de equipe para criar o primeiro acesso de
            revisao.
          </div>
        )}
      </div>
    </article>
  </section>

  <section class="mt-8 rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Auditoria</p>
        <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Eventos recentes da mesa</h2>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600">
          O portal cliente mostra a trilha recente ligada a revisores e mesa a partir do recorte oficial do backend,
          sem duplicar regra documental no frontend.
        </p>
      </div>

      <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
        {mesa.summary.mesaAuditEvents} eventos
      </div>
    </div>

    <div class="mt-6 space-y-3">
      {mesa.recentAudit.length > 0 ? mesa.recentAudit.map((entry) => (
        <article class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <p class="font-semibold text-slate-950">{entry.summary}</p>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">{entry.portal}</p>
          </div>
          <p class="mt-2 text-sm leading-6 text-slate-600">{entry.action}</p>
          <p class="mt-2 text-sm text-slate-500">
            {entry.createdAt ? dateTimeFormatter.format(entry.createdAt) : entry.createdAtLabel}
          </p>
        </article>
      )) : (
        <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
          Ainda nao ha eventos recentes classificados como mesa ou revisor na trilha do tenant.
        </div>
      )}
    </div>
  </section>
</ClientShellLayout>
