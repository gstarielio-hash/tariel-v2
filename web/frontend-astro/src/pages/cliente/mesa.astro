---
import {
  AlertTriangle,
  ArrowRight,
  CheckCircle2,
  FileSearch,
  FileStack,
  LockKeyhole,
  MessageSquare,
  Paperclip,
  Search,
  Send,
  ShieldCheck,
  Users,
} from "lucide-react";

import ClientNotice from "@/components/app/client/client-notice.astro";
import ClientShellLayout from "@/layouts/client-shell-layout.astro";
import { consumeClientNotice } from "@/lib/server/client-notice";
import {
  getClientMesaWorkspace,
  normalizeClientMesaSection,
  type ClientMesaPackageMessage,
  type ClientMesaSection,
  type ClientMesaThreadMessage,
} from "@/lib/server/client-mesa";

export const prerender = false;

const clientSession = Astro.locals.clientSession;

if (!clientSession) {
  return Astro.redirect("/cliente/login", 303);
}

const searchParams = Astro.url.searchParams;
const section = normalizeClientMesaSection(searchParams.get("sec"));
const searchTerm = String(searchParams.get("busca") ?? "").trim();
const requestedLaudoId = Number(searchParams.get("laudo") ?? 0);
const workspace = await getClientMesaWorkspace(clientSession, {
  section,
  searchTerm,
  selectedLaudoId: Number.isInteger(requestedLaudoId) && requestedLaudoId > 0 ? requestedLaudoId : null,
});

if (!workspace) {
  throw new Error("Empresa do portal cliente nao encontrada.");
}

const currentClientUserId = clientSession.user.id;
const currentSection = workspace.section;
const currentSearchTerm = workspace.searchTerm;
const notice = consumeClientNotice(Astro.cookies);
const selectedCase = workspace.selectedCase;
const selectedPackage = selectedCase?.package ?? null;
const defaultSelectedId =
  selectedCase?.item.id ??
  workspace.filteredQueueCases[0]?.id ??
  workspace.pendingCases[0]?.id ??
  workspace.filteredHistoryCases[0]?.id ??
  null;
const currentReturnTo = buildMesaPath({
  section: workspace.section,
  searchTerm: workspace.searchTerm,
  selectedLaudoId: selectedCase?.item.id ?? null,
});
const canApprove = Boolean(selectedPackage?.allowedSurfaceActions.includes("mesa_approve"));
const canReturn = Boolean(selectedPackage?.allowedSurfaceActions.includes("mesa_return"));
const queueCards = [
  { label: "Rascunhos", value: workspace.snapshot.summary.drafts, tone: "neutral" },
  { label: "Aguardando avaliacao", value: workspace.snapshot.summary.waitingReview, tone: "warning" },
  { label: "Aprovados", value: workspace.snapshot.summary.approved, tone: "success" },
  { label: "Rejeitados", value: workspace.snapshot.summary.rejected, tone: "danger" },
] as const;
const summaryCards = [
  {
    label: "Equipe de analise",
    value: workspace.snapshot.summary.reviewers,
    detail:
      workspace.snapshot.summary.reviewers > 0
        ? `${workspace.snapshot.summary.reviewers} revisores provisionados para a empresa.`
        : "Nenhum revisor provisionado ainda no tenant.",
    icon: Users,
  },
  {
    label: "Sessoes da mesa",
    value: workspace.snapshot.summary.reviewerSessions,
    detail: "Revisores com atividade recente no tenant.",
    icon: ShieldCheck,
  },
  {
    label: "Aguardando avaliacao",
    value: workspace.snapshot.summary.waitingReview,
    detail: "Casos ativos esperando decisao da mesa.",
    icon: FileStack,
  },
  {
    label: "Primeiro acesso",
    value: workspace.snapshot.summary.reviewerFirstAccessPending,
    detail: "Contas que ainda precisam trocar a senha inicial.",
    icon: LockKeyhole,
  },
] as const;
const tabs = [
  {
    key: "overview",
    label: "Visao geral",
    detail: `${workspace.snapshot.detail.totalReports} laudos governados no tenant.`,
  },
  {
    key: "queue",
    label: "Fila",
    detail: `${workspace.filteredQueueCases.length} casos ativos no recorte atual.`,
  },
  {
    key: "pending",
    label: "Pendencias",
    detail: `${workspace.pendingCases.length} casos com whisper, pendencia ou aprendizado.`,
  },
  {
    key: "reply",
    label: "Responder",
    detail: selectedCase ? `Laudo ${selectedCase.item.hashShort}` : "Selecione um laudo para agir.",
  },
] as const satisfies { key: ClientMesaSection; label: string; detail: string }[];

function buildMesaPath(input: {
  section?: ClientMesaSection;
  searchTerm?: string;
  selectedLaudoId?: number | null;
}) {
  const params = new URLSearchParams();
  const nextSection = input.section ?? currentSection;
  const nextSearch = String(input.searchTerm ?? currentSearchTerm).trim();
  const nextLaudoId = input.selectedLaudoId ?? null;

  if (nextSection !== "overview") {
    params.set("sec", nextSection);
  }
  if (nextSearch) {
    params.set("busca", nextSearch);
  }
  if (nextLaudoId) {
    params.set("laudo", String(nextLaudoId));
  }

  const query = params.toString();
  return query ? `/cliente/mesa?${query}` : "/cliente/mesa";
}

function toneClass(tone: (typeof queueCards)[number]["tone"]) {
  if (tone === "success") return "border-emerald-200 bg-emerald-50";
  if (tone === "warning") return "border-amber-200 bg-amber-50";
  if (tone === "danger") return "border-red-200 bg-red-50";
  return "border-slate-200 bg-slate-50";
}

function queueItemClass(itemId: number) {
  return itemId === selectedCase?.item.id
    ? "border-sky-400 bg-sky-50 shadow-[0_18px_40px_rgba(14,165,233,0.08)]"
    : "border-slate-200 bg-slate-50 hover:border-slate-300 hover:bg-white";
}

function messageCardClass(message: ClientMesaThreadMessage | ClientMesaPackageMessage) {
  if (message.messageKind === "mesa_pendency" && message.pendencyState === "resolved") {
    return "border-emerald-200 bg-emerald-50";
  }
  if (message.messageKind === "mesa_pendency") {
    return "border-red-200 bg-red-50";
  }
  if ("isWhisper" in message && message.isWhisper) {
    return "border-amber-200 bg-amber-50";
  }
  return "border-slate-200 bg-slate-50";
}

function messageLabel(message: ClientMesaThreadMessage | ClientMesaPackageMessage) {
  if (message.messageKind === "mesa_pendency") {
    return message.pendencyState === "resolved" ? "Pendencia resolvida" : "Pendencia aberta";
  }
  if ("isWhisper" in message && message.isWhisper) {
    return message.senderId === currentClientUserId ? "Whisper enviado" : "Whisper do campo";
  }
  if (message.senderId === currentClientUserId) {
    return "Resposta do tenant";
  }
  return "Trilha da mesa";
}

function formatBytes(value: number) {
  if (value <= 0) {
    return "0 B";
  }

  const units = ["B", "KB", "MB", "GB"];
  let size = value;
  let unitIndex = 0;

  while (size >= 1024 && unitIndex < units.length - 1) {
    size /= 1024;
    unitIndex += 1;
  }

  return `${size.toFixed(size >= 10 || unitIndex === 0 ? 0 : 1)} ${units[unitIndex]}`;
}

const activeListTitle =
  workspace.section === "pending" ? "Casos com pendencia operacional" : "Fila ativa governada";
const activeListItems = workspace.section === "pending" ? workspace.pendingCases : workspace.filteredQueueCases;
---

<ClientShellLayout
  title={`Mesa | ${workspace.snapshot.detail.companyName} | Tariel Astro`}
  description="Mesa do cliente em Astro SSR com leitura detalhada, resposta, decisão e pendências governadas pelo backend Python."
  userName={clientSession.user.name}
  companyName={workspace.snapshot.detail.companyName}
  activeItem="mesa"
>
  <Fragment slot="header">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-600">Mesa do cliente</p>
        <h1 class="mt-3 font-display text-3xl tracking-tight text-slate-950 sm:text-4xl">
          Fila, thread e decisao no V2
        </h1>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600">
          Este slice fecha a operacao principal de <code>/cliente/mesa</code> no Astro: a interface fica no portal
          novo, mas a leitura, as respostas, as pendencias e a decisao continuam ownership do backend Python.
        </p>
      </div>

      <div class="rounded-[28px] border border-sky-500/16 bg-sky-500/6 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-700">Estado atual</p>
        <p class="mt-2 text-lg font-semibold text-slate-950">{workspace.snapshot.detail.healthLabel}</p>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          {workspace.snapshot.summary.waitingReview} casos aguardando avaliacao, {workspace.snapshot.queue.pendingWhispers}
          {" "}whispers pendentes e {workspace.snapshot.queue.openPendencies} pendencias abertas.
        </p>
      </div>
    </div>
  </Fragment>

  <ClientNotice notice={notice} />

  <section class="grid gap-4 xl:grid-cols-4">
    {summaryCards.map(({ label, value, detail, icon: Icon }) => (
      <article class="rounded-[30px] border border-slate-950/8 bg-white p-5 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{label}</p>
          <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
            <Icon className="size-5" />
          </div>
        </div>
        <p class="mt-5 font-display text-3xl tracking-tight text-slate-950">{value}</p>
        <p class="mt-3 text-sm leading-6 text-slate-600">{detail}</p>
      </article>
    ))}
  </section>

  <section class="mt-8 grid gap-3 xl:grid-cols-4">
    {tabs.map((tab) => (
      <a
        href={buildMesaPath({
          section: tab.key,
          searchTerm: workspace.searchTerm,
          selectedLaudoId: tab.key === "overview" ? null : defaultSelectedId,
        })}
        class:list={[
          "rounded-[28px] border px-5 py-4 transition",
          workspace.section === tab.key
            ? "border-sky-400 bg-sky-50 shadow-[0_18px_40px_rgba(14,165,233,0.08)]"
            : "border-slate-200 bg-white hover:border-slate-300 hover:bg-slate-50",
        ]}
      >
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{tab.label}</p>
        <p class="mt-3 text-base font-semibold text-slate-950">{tab.detail}</p>
      </a>
    ))}
  </section>

  {workspace.section === "overview" ? (
    <>
      <section class="mt-8 grid gap-6 xl:grid-cols-[0.92fr_1.08fr]">
        <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Cobertura do slice</p>
              <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">O que ja esta fechado</h2>
            </div>

            <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
              Slice 3
            </div>
          </div>

          <div class="mt-6 grid gap-3">
            <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
              <p class="text-sm font-semibold text-slate-950">Fila governada no Astro</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                O portal cliente agora navega a fila ativa, o histórico e os casos com pendência sem inferir a mesa
                direto do banco.
              </p>
            </div>

            <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
              <p class="text-sm font-semibold text-slate-950">Thread operacional e anexos</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                Mensagens, whispers, pendências e download de anexo passam pelo Astro, mas continuam governados pelo
                contrato Python.
              </p>
            </div>

            <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
              <p class="text-sm font-semibold text-slate-950">Mutacoes principais</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                Responder, anexar, resolver pendência, aprovar e devolver agora usam action routes SSR no portal novo.
              </p>
            </div>

            <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-950">Proxima camada</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                Depois desta vertical, a migração pode avançar para <code>/revisao</code> sem deixar a mesa do cliente
                dependente do shell legado.
              </p>
            </div>
          </div>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a
              href={buildMesaPath({ section: "queue", selectedLaudoId: defaultSelectedId })}
              class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(15,23,42,0.18)] transition hover:bg-slate-800"
            >
              Abrir fila governada
              <ArrowRight className="size-4" />
            </a>

            <a
              href="/cliente/equipe"
              class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50"
            >
              Gerir revisores
              <ArrowRight className="size-4" />
            </a>
          </div>
        </article>

        <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Distribuicao da fila</p>
              <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Status do tenant</h2>
            </div>

            <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
              {workspace.snapshot.detail.totalReports} laudos
            </div>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {queueCards.map((card) => (
              <div class:list={["rounded-[24px] border px-4 py-4", toneClass(card.tone)]}>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">{card.label}</p>
                <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">{card.value}</p>
              </div>
            ))}
          </div>

          <div class="mt-6 rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-600">
            {workspace.snapshot.queue.inField.length} em andamento, {workspace.snapshot.queue.awaitingReview.length} na
            fila de avaliacao e {workspace.snapshot.queue.history.length} no historico recente.
          </div>
        </article>
      </section>

      <section class="mt-8 grid gap-6 xl:grid-cols-[1.04fr_0.96fr]">
        <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Fila governada</p>
              <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Casos recentes</h2>
            </div>

            <a
              href={buildMesaPath({ section: "reply", selectedLaudoId: defaultSelectedId })}
              class="inline-flex items-center gap-2 rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 transition hover:border-slate-300 hover:bg-slate-50"
            >
              Abrir thread
              <ArrowRight className="size-4" />
            </a>
          </div>

          <div class="mt-6 space-y-3">
            {workspace.snapshot.recentCases.length > 0 ? workspace.snapshot.recentCases.map((report) => (
              <a
                href={buildMesaPath({ section: "reply", selectedLaudoId: report.id })}
                class="block rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4 transition hover:border-slate-300 hover:bg-white"
              >
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="font-semibold text-slate-950">{report.sector || `Laudo ${report.hashShort}`}</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">
                      {report.title} • {report.operationLabel} • inspetor {report.inspectorName}
                    </p>
                    <p class="mt-1 text-sm leading-6 text-slate-500">
                      {report.whispersPending} whispers • {report.openPendencies} pendencias • {report.pendingLearning}
                      {" "}aprendizados pendentes
                    </p>
                  </div>

                  <div class="flex flex-col items-start gap-2 sm:items-end">
                    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
                      {report.statusVisualLabel}
                    </span>
                    <p class="text-sm text-slate-500">{report.updatedAtLabel}</p>
                  </div>
                </div>
              </a>
            )) : (
              <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
                Nenhum laudo recente foi encontrado para a mesa deste tenant.
              </div>
            )}
          </div>
        </article>

        <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Auditoria da mesa</p>
              <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Eventos recentes</h2>
            </div>

            <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
              {workspace.snapshot.recentAudit.length} eventos
            </div>
          </div>

          <div class="mt-6 space-y-3">
            {workspace.snapshot.recentAudit.length > 0 ? workspace.snapshot.recentAudit.map((entry) => (
              <article class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                  <p class="font-semibold text-slate-950">{entry.summary}</p>
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
                    {entry.portal} • {entry.createdAtLabel}
                  </p>
                </div>

                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {entry.detail ?? entry.action}
                </p>
              </article>
            )) : (
              <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
                Nenhum evento recente foi encontrado para este tenant.
              </div>
            )}
          </div>
        </article>
      </section>
    </>
  ) : (
    <section class="mt-8 grid gap-6 xl:grid-cols-[0.96fr_1.04fr]">
      <div class="space-y-6">
        <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">{activeListTitle}</p>
              <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">
                {workspace.section === "pending" ? "Casos que pedem retorno" : "Selecione um laudo"}
              </h2>
            </div>

            <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
              <Search className="size-5" />
            </div>
          </div>

          <form method="GET" action="/cliente/mesa" class="mt-6 space-y-4">
            <input type="hidden" name="sec" value={workspace.section} />
            {selectedCase ? <input type="hidden" name="laudo" value={selectedCase.item.id} /> : null}

            <label class="block space-y-2">
              <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Buscar na fila</span>
              <div class="relative">
                <Search className="pointer-events-none absolute left-4 top-1/2 size-4 -translate-y-1/2 text-slate-400" />
                <input
                  type="text"
                  name="busca"
                  value={workspace.searchTerm}
                  placeholder="Hash, setor, inspetor ou proxima acao"
                  class="w-full rounded-2xl border border-slate-200 bg-white px-11 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-sky-500"
                />
              </div>
            </label>

            <div class="flex gap-3">
              <button
                type="submit"
                class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
              >
                Filtrar fila
              </button>
              <a
                href={buildMesaPath({ section: workspace.section, selectedLaudoId: defaultSelectedId, searchTerm: "" })}
                class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50"
              >
                Limpar busca
              </a>
            </div>
          </form>

          <div class="mt-6 space-y-3">
            {activeListItems.length > 0 ? activeListItems.map((item) => (
              <a
                href={buildMesaPath({ section: workspace.section, searchTerm: workspace.searchTerm, selectedLaudoId: item.id })}
                class:list={["block rounded-[24px] border px-4 py-4 transition", queueItemClass(item.id)]}
              >
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="font-semibold text-slate-950">{item.sector || `Laudo ${item.hashShort}`}</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">{item.title}</p>
                    <p class="mt-1 text-sm leading-6 text-slate-500">
                      {item.operationLabel} • {item.priorityLabel} • inspetor {item.inspectorName}
                    </p>
                  </div>

                  <div class="flex flex-col items-start gap-2 sm:items-end">
                    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
                      {item.statusVisualLabel}
                    </span>
                    <p class="text-xs uppercase tracking-[0.18em] text-slate-400">{item.updatedAtLabel}</p>
                  </div>
                </div>

                <div class="mt-4 flex flex-wrap gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1">{item.hashShort}</span>
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1">{item.whispersPending} whispers</span>
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1">{item.openPendencies} pendencias</span>
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1">{item.pendingLearning} aprendizados</span>
                </div>
