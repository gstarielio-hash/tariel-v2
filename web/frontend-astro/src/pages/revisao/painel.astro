---
import {
  AlertTriangle,
  CheckCircle2,
  ClipboardList,
  FileSearch,
  MessageSquareReply,
  Paperclip,
  Search,
  Send,
  ShieldCheck,
  Workflow,
} from "lucide-react";

import ReviewerNotice from "@/components/app/reviewer/reviewer-notice.astro";
import ReviewerShellLayout from "@/layouts/reviewer-shell-layout.astro";
import { getReviewerMesaWorkspace } from "@/lib/server/reviewer-mesa";
import { consumeReviewerNotice } from "@/lib/server/reviewer-notice";
import type { ReviewQueueItemPayload } from "@/lib/server/reviewer-panel-bridge";

export const prerender = false;

const reviewerSession = Astro.locals.reviewerSession;
if (!reviewerSession) {
  return Astro.redirect("/revisao/login", 303);
}

const searchTerm = String(Astro.url.searchParams.get("q") ?? "").trim();
const operationFilter = String(Astro.url.searchParams.get("operacao") ?? "").trim().toLowerCase();
const learningFilter = String(Astro.url.searchParams.get("aprendizados") ?? "").trim().toLowerCase();
const requestedLaudoId = Number(Astro.url.searchParams.get("laudo") ?? 0);
const workspace = await getReviewerMesaWorkspace(reviewerSession, {
  searchTerm,
  operationFilter,
  learningFilter,
  selectedLaudoId: Number.isInteger(requestedLaudoId) && requestedLaudoId > 0 ? requestedLaudoId : null,
});

const currentReviewerUserId = reviewerSession.user.id;
const notice = consumeReviewerNotice(Astro.cookies);
const payload = workspace.projection.payload;
const selectedCase = workspace.selectedCase;
const selectedPackage = selectedCase?.package ?? null;
const currentReturnTo = buildPanelPath({
  q: workspace.searchTerm,
  operacao: workspace.operationFilter,
  aprendizados: workspace.learningFilter,
  laudo: selectedCase?.item.id ?? null,
});
const canApprove = Boolean(selectedPackage?.allowedSurfaceActions.includes("mesa_approve"));
const canReturn = Boolean(selectedPackage?.allowedSurfaceActions.includes("mesa_return"));
const eligibleSignatories = selectedPackage?.officialIssue?.signatories.filter((item) =>
  ["ready", "expiring_soon"].includes(item.status),
) ?? [];

const statCards = [
  {
    label: "Em andamento",
    value: payload.queue_summary.in_field_count,
    detail: "Casos em campo ou acompanhamento da mesa.",
    icon: Workflow,
  },
  {
    label: "Aguardando mesa",
    value: payload.queue_summary.awaiting_review_count,
    detail: "Casos prontos para decisao ou triagem final.",
    icon: ClipboardList,
  },
  {
    label: "Whispers pendentes",
    value: payload.queue_summary.whisper_pending_count,
    detail: "Mensagens do campo aguardando retorno da mesa.",
    icon: MessageSquareReply,
  },
  {
    label: "Pendencias abertas",
    value: payload.queue_summary.total_open_pendencies,
    detail: "Pendencias operacionais ainda sem fechamento.",
    icon: ShieldCheck,
  },
] as const;

const operationCards = [
  { label: "Responder agora", key: "responder_agora", value: payload.operation_totals.responder_agora },
  { label: "Validar aprendizado", key: "validar_aprendizado", value: payload.operation_totals.validar_aprendizado },
  { label: "Aguardando campo", key: "aguardando_inspetor", value: payload.operation_totals.aguardando_inspetor },
  { label: "Fechamento", key: "fechamento_mesa", value: payload.operation_totals.fechamento_mesa },
  { label: "Acompanhamento", key: "acompanhamento", value: payload.operation_totals.acompanhamento },
] as const;

function buildPanelPath(input: {
  q?: string | null;
  operacao?: string | null;
  aprendizados?: string | null;
  laudo?: number | null;
}) {
  const params = new URLSearchParams();
  if (String(input.q ?? "").trim()) params.set("q", String(input.q).trim());
  if (String(input.operacao ?? "").trim()) params.set("operacao", String(input.operacao).trim());
  if (String(input.aprendizados ?? "").trim()) params.set("aprendizados", String(input.aprendizados).trim());
  if (input.laudo) params.set("laudo", String(input.laudo));
  const query = params.toString();
  return query ? `/revisao/painel?${query}` : "/revisao/painel";
}

function statusTone(item: ReviewQueueItemPayload) {
  if (item.prioridade_operacional === "critica") return "border-red-200 bg-red-50";
  if (item.prioridade_operacional === "alta") return "border-amber-200 bg-amber-50";
  if (item.queue_section === "historico") return "border-slate-200 bg-slate-50";
  return "border-emerald-200 bg-emerald-50";
}

function queueItemClass(itemId: number) {
  return itemId === selectedCase?.item.id
    ? "border-emerald-400 bg-emerald-50 shadow-[0_18px_40px_rgba(16,185,129,0.08)]"
    : "border-slate-200 bg-slate-50 hover:border-slate-300 hover:bg-white";
}

function messageCardClass(message: {
  messageKind: string;
  pendencyState: string;
  isWhisper?: boolean;
}) {
  if (message.messageKind === "mesa_pendency" && message.pendencyState === "resolved") {
    return "border-emerald-200 bg-emerald-50";
  }
  if (message.messageKind === "mesa_pendency") {
    return "border-red-200 bg-red-50";
  }
  if (message.isWhisper) {
    return "border-amber-200 bg-amber-50";
  }
  return "border-slate-200 bg-slate-50";
}

function messageLabel(message: {
  messageKind: string;
  pendencyState: string;
  isWhisper?: boolean;
  senderId: number | null;
}) {
  if (message.messageKind === "mesa_pendency") {
    return message.pendencyState === "resolved" ? "Pendencia resolvida" : "Pendencia aberta";
  }
  if (message.isWhisper) {
    return message.senderId === currentReviewerUserId ? "Whisper da mesa" : "Whisper do campo";
  }
  if (message.senderId === currentReviewerUserId) {
    return "Resposta da mesa";
  }
  return "Trilha operacional";
}

function formatBytes(value: number) {
  if (value <= 0) {
    return "0 B";
  }

  const units = ["B", "KB", "MB", "GB"];
  let size = value;
  let unitIndex = 0;

  while (size >= 1024 && unitIndex < units.length - 1) {
    size /= 1024;
    unitIndex += 1;
  }

  return `${size.toFixed(size >= 10 || unitIndex === 0 ? 0 : 1)} ${units[unitIndex]}`;
}
---

<ReviewerShellLayout
  title={`Mesa Avaliadora | ${reviewerSession.user.companyName} | Tariel Astro`}
  description="Mesa avaliadora em Astro SSR com fila, thread, respostas e decisao governadas pelo backend Python."
  userName={reviewerSession.user.name}
  companyName={reviewerSession.user.companyName}
  activeItem="dashboard"
>
  <Fragment slot="header">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-600">Mesa Avaliadora</p>
        <h1 class="mt-3 font-display text-3xl tracking-tight text-slate-950 sm:text-4xl">
          Fila, thread e decisao no V2
        </h1>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600">
          Este slice abre a workspace principal de <code>/revisao/painel</code> no Astro: o shell fica no portal novo,
          mas a fila, a thread, as pendencias e as decisoes continuam ownership do backend Python.
        </p>
      </div>

      <div class="rounded-[28px] border border-emerald-500/16 bg-emerald-500/6 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-emerald-700">Estado atual</p>
        <p class="mt-2 text-lg font-semibold text-slate-950">{payload.queue_summary.observed_case_ids.length} casos observados</p>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          {payload.queue_summary.total_pending_whispers} whispers pendentes, {payload.queue_summary.total_pending_learning}
          {" "}aprendizados e {payload.queue_summary.total_open_pendencies} pendencias abertas.
        </p>
      </div>
    </div>
  </Fragment>

  <ReviewerNotice notice={notice} />

  <section class="grid gap-4 xl:grid-cols-4">
    {statCards.map(({ label, value, detail, icon: Icon }) => (
      <article class="rounded-[30px] border border-slate-950/8 bg-white p-5 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{label}</p>
          <div class="rounded-2xl bg-emerald-500/10 p-3 text-emerald-700">
            <Icon className="size-5" />
          </div>
        </div>
        <p class="mt-5 font-display text-3xl tracking-tight text-slate-950">{value}</p>
        <p class="mt-3 text-sm leading-6 text-slate-600">{detail}</p>
      </article>
    ))}
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[0.94fr_1.06fr]">
    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Filtros da fila</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Recorte operacional</h2>
        </div>
        <div class="rounded-2xl bg-emerald-500/10 p-3 text-emerald-700">
          <Search className="size-5" />
        </div>
      </div>

      <form method="GET" action="/revisao/painel" class="mt-6 space-y-4">
        <label class="block space-y-2">
          <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Buscar na fila</span>
          <input
            type="text"
            name="q"
            value={workspace.searchTerm}
            placeholder="Hash, setor, inspetor ou mensagem inicial"
            class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-emerald-500"
          />
        </label>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Operacao</span>
            <select
              name="operacao"
              class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-emerald-500"
            >
              <option value="">Todas</option>
              <option value="responder_agora" selected={workspace.operationFilter === "responder_agora"}>Responder agora</option>
              <option value="validar_aprendizado" selected={workspace.operationFilter === "validar_aprendizado"}>Validar aprendizado</option>
              <option value="aguardando_inspetor" selected={workspace.operationFilter === "aguardando_inspetor"}>Aguardando campo</option>
              <option value="fechamento_mesa" selected={workspace.operationFilter === "fechamento_mesa"}>Fechamento</option>
              <option value="acompanhamento" selected={workspace.operationFilter === "acompanhamento"}>Acompanhamento</option>
            </select>
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Aprendizados</span>
            <select
              name="aprendizados"
              class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-emerald-500"
            >
              <option value="">Todos</option>
              <option value="pendentes" selected={workspace.learningFilter === "pendentes"}>Somente pendentes</option>
            </select>
          </label>
        </div>

        <div class="flex gap-3">
          <button
            type="submit"
            class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
          >
            Aplicar filtros
          </button>
          <a
            href="/revisao/painel"
            class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50"
          >
            Limpar
          </a>
        </div>
      </form>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
        {operationCards.map((card) => (
          <a
            href={buildPanelPath({
              q: workspace.searchTerm,
              operacao: card.key,
              aprendizados: workspace.learningFilter,
              laudo: selectedCase?.item.id ?? null,
            })}
            class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4 transition hover:border-slate-300 hover:bg-white"
          >
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">{card.label}</p>
            <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">{card.value}</p>
          </a>
        ))}
      </div>
    </article>

    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Whispers</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Retornos recentes do campo</h2>
        </div>
        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {payload.pending_whispers_preview.length} itens
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {payload.pending_whispers_preview.length > 0 ? payload.pending_whispers_preview.map((item) => (
          <a
            href={buildPanelPath({
              q: workspace.searchTerm,
              operacao: workspace.operationFilter,
              aprendizados: workspace.learningFilter,
              laudo: item.laudo_id,
            })}
            class="block rounded-[24px] border border-amber-200 bg-amber-50 px-4 py-4 transition hover:border-amber-300 hover:bg-amber-100/70"
          >
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <p class="font-semibold text-slate-950">Laudo {item.hash}</p>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{item.status_visual_label}</p>
            </div>
            <p class="mt-2 text-sm leading-6 text-slate-700">{item.texto}</p>
            <p class="mt-2 text-sm leading-6 text-slate-500">
              {item.collaboration_summary?.unread_whisper_count ?? 0} nao lidos • {item.collaboration_summary?.open_pendency_count ?? 0} pendencias abertas
            </p>
          </a>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Nenhum whisper pendente apareceu no recorte atual da fila.
          </div>
        )}
      </div>
    </article>
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[0.82fr_1.18fr]">
    <div class="space-y-6">
      {[
        { title: "Em andamento", items: payload.queue_sections.em_andamento },
        { title: "Aguardando avaliacao", items: payload.queue_sections.aguardando_avaliacao },
        { title: "Historico recente", items: payload.queue_sections.historico },
      ].map(({ title, items }) => (
        <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Fila</p>
              <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">{title}</h2>
            </div>
            <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
              {items.length} itens
            </div>
          </div>

          <div class="mt-6 space-y-3">
            {items.length > 0 ? items.map((item) => (
              <a
                href={buildPanelPath({
                  q: workspace.searchTerm,
                  operacao: workspace.operationFilter,
                  aprendizados: workspace.learningFilter,
                  laudo: item.id,
                })}
                class:list={["block rounded-[24px] border px-4 py-4 transition", queueItemClass(item.id), statusTone(item)]}
              >
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="font-semibold text-slate-950">{item.setor_industrial || `Laudo ${item.hash_curto}`}</p>
                    <p class="mt-1 text-sm leading-6 text-slate-600">{item.primeira_mensagem}</p>
                    <p class="mt-1 text-sm leading-6 text-slate-500">
                      {item.inspetor_nome} • {item.tempo_em_campo} • {item.proxima_acao}
                    </p>
                  </div>

                  <div class="flex flex-col items-start gap-2 sm:items-end">
                    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
                      {item.status_visual_label}
                    </span>
                    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
                      {item.fila_operacional_label}
                    </span>
                  </div>
                </div>

                <div class="mt-4 flex flex-wrap gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1">{item.hash_curto}</span>
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1">{item.whispers_nao_lidos} whispers</span>
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1">{item.pendencias_abertas} pendencias</span>
                  <span class="rounded-full border border-slate-200 bg-white px-3 py-1">{item.aprendizados_pendentes} aprendizados</span>
                </div>
              </a>
            )) : (
              <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
                Nenhum caso encontrado nesta secao para o filtro atual.
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

    <div class="space-y-6">
      {selectedCase && selectedPackage ? (
        <>
          <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Laudo selecionado</p>
                <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">
                  {selectedCase.item.setor_industrial || `Laudo ${selectedCase.item.hash_curto}`}
                </h2>
                <p class="mt-3 text-sm leading-7 text-slate-600">{selectedCase.item.primeira_mensagem}</p>
              </div>

              <div class="flex flex-col gap-2">
                <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
                  {selectedPackage.statusVisualLabel}
                </span>
                <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-600">
                  Hash {selectedCase.item.hash_curto}
                </span>
              </div>
            </div>

            <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
              <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Fluxo</p>
                <p class="mt-3 text-sm font-semibold text-slate-950">{selectedPackage.lifecycleStatus || "Sem lifecycle"}</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">{selectedPackage.activeOwnerRole || "Owner nao informado"}</p>
              </div>

              <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Mensagens</p>
                <p class="mt-3 text-sm font-semibold text-slate-950">{selectedPackage.messageSummary.total}</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedPackage.messageSummary.inspector} inspetor • {selectedPackage.messageSummary.mesa} mesa
                </p>
              </div>

              <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Pendencias</p>
                <p class="mt-3 text-sm font-semibold text-slate-950">{selectedPackage.pendencySummary.open}</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedPackage.pendencySummary.resolved} resolvidas recentemente
                </p>
              </div>

              <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Ultima interacao</p>
                <p class="mt-3 text-sm font-semibold text-slate-950">{selectedPackage.lastInteractionLabel}</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedPackage.fieldTimeMinutes} min em campo • {selectedCase.item.inspetor_nome}
                </p>
              </div>
            </div>

            {selectedPackage.aiSummary ? (
              <div class="mt-6 rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm leading-6 text-slate-700">
                <p class="font-semibold text-slate-950">Resumo de apoio</p>
                <p class="mt-2 whitespace-pre-wrap">{selectedPackage.aiSummary}</p>
              </div>
            ) : null}
          </article>

          <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Triagem operacional</p>
                <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Pendencias e whispers</h2>
              </div>

              {selectedCase.item.whispers_nao_lidos > 0 ? (
                <form method="POST" action={`/revisao/painel/${selectedCase.item.id}/marcar-whispers-lidos`}>
                  <input type="hidden" name="returnTo" value={currentReturnTo} />
                  <button
                    type="submit"
                    class="inline-flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50"
                  >
                    Marcar whispers lidos
                  </button>
                </form>
              ) : null}
            </div>

            <div class="mt-6 grid gap-6 xl:grid-cols-2">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Pendencias abertas</p>
                <div class="mt-4 space-y-3">
                  {selectedPackage.openPendencies.length > 0 ? selectedPackage.openPendencies.map((message) => (
