---
import {
  AlertTriangle,
  CheckCircle2,
  Clock3,
  FileStack,
  Fingerprint,
  MessageCircle,
  MessageCircleWarning,
  MessageSquareCode,
  ScanSearch,
  ShieldCheck,
  Workflow,
} from "lucide-react";

import AppShellLayout from "@/layouts/app-shell-layout.astro";
import { consumeAppNotice } from "@/lib/server/app-notice";
import { fetchAppMesaMessages, fetchAppMesaSummary } from "@/lib/server/app-mesa-bridge";
import { getAppPortalOverview } from "@/lib/server/app-portal";

export const prerender = false;

const appSession = Astro.locals.appSession;

if (!appSession) {
  return Astro.redirect("/app/login", 303);
}

const overview = await getAppPortalOverview({
  userId: appSession.user.id,
  companyId: appSession.user.companyId,
});

if (!overview) {
  throw new Error("Perfil do portal do inspetor nao encontrado.");
}

const successMessage = String(Astro.url.searchParams.get("sucesso") ?? "").trim();
const notice = consumeAppNotice(Astro.cookies);
const selectedLaudoId = Number(Astro.url.searchParams.get("laudo") ?? 0) || overview.recentReports[0]?.id || 0;
const selectedReferenceMessageId = Number(Astro.url.searchParams.get("ref") ?? 0) || 0;
const selectedReport = overview.recentReports.find((report) => report.id === selectedLaudoId) ?? overview.recentReports[0] ?? null;
const selectedSummary = selectedReport
  ? await fetchAppMesaSummary(appSession, selectedReport.id).catch(() => null)
  : null;
const selectedMessages = selectedReport
  ? await fetchAppMesaMessages(appSession, selectedReport.id).catch(() => null)
  : null;
const threadPreview = selectedMessages?.itens.slice(-6).reverse() ?? [];
const referencedMessage = threadPreview.find((message) => message.id === selectedReferenceMessageId) ?? null;
const dateTimeFormatter = new Intl.DateTimeFormat("pt-BR", {
  dateStyle: "short",
  timeStyle: "short",
});

const cards = [
  {
    label: "Portal",
    value: "Inspetor",
    detail: "Sessao oficial emitida no Astro SSR com persistencia em Prisma.",
    icon: Fingerprint,
  },
  {
    label: "Empresa",
    value: overview.company.name,
    detail: overview.profile.email,
    icon: ShieldCheck,
  },
  {
    label: "Laudos do inspetor",
    value: overview.summary.totalReports,
    detail: `${overview.summary.reportsLast30Days} criados nos ultimos 30 dias.`,
    icon: FileStack,
  },
  {
    label: "Ultima atividade",
    value: overview.summary.latestActivityLabel,
    detail: `${overview.summary.activeSessions} sessoes ativas neste portal.`,
    icon: Clock3,
  },
  {
    label: "Expira em",
    value: dateTimeFormatter.format(appSession.session.expiresAt),
    detail: appSession.session.remember ? "Sessao com lembrar ativado." : "Sessao padrao do navegador.",
    icon: Workflow,
  },
];
---

<AppShellLayout
  title="Portal do Inspetor | Tariel Astro"
  description="Home inicial autenticada do inspetor no Astro SSR."
  userName={overview.profile.name}
  companyName={overview.company.name}
  activeItem="dashboard"
>
  <Fragment slot="header">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-600">Portal do inspetor</p>
        <h1 class="mt-3 font-display text-3xl tracking-tight text-slate-950 sm:text-4xl">
          {overview.profile.name}
        </h1>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600">
          Sessao oficial do inspetor ativa no Astro SSR. Esta home agora mostra contexto real do operador, seus laudos
          recentes e trilha de auditoria sem puxar ainda a workspace operacional pesada.
        </p>
      </div>

      <div class="rounded-[28px] border border-sky-500/16 bg-sky-500/6 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-700">Status da migracao</p>
        <p class="mt-2 text-lg font-semibold text-slate-950">Overview operacional inicial entregue</p>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          Entrada, sessao e primeira leitura real do portal ja sairam do legado.
        </p>
      </div>
    </div>
  </Fragment>

  {successMessage ? (
    <div class="mb-6 rounded-[24px] border border-emerald-500/18 bg-emerald-500/8 px-4 py-3 text-sm leading-6 text-emerald-900">
      {successMessage}
    </div>
  ) : null}

  {notice ? (
    <div
      class:list={[
        "mb-6 rounded-[24px] border px-4 py-4 text-sm leading-6",
        notice.tone === "success"
          ? "border-emerald-500/18 bg-emerald-500/8 text-emerald-900"
          : notice.tone === "error"
            ? "border-rose-500/18 bg-rose-500/8 text-rose-900"
            : "border-sky-500/18 bg-sky-500/8 text-sky-950",
      ]}
    >
      <div class="flex items-start gap-3">
        <div class="rounded-2xl bg-white/80 p-2 text-slate-950 shadow-sm">
          {notice.tone === "success" ? <CheckCircle2 className="size-4" /> : <AlertTriangle className="size-4" />}
        </div>
        <div>
          <p class="font-semibold">{notice.title}</p>
          <p class="mt-1">{notice.message}</p>
          {notice.details && notice.details.length > 0 ? (
            <div class="mt-2 space-y-1 text-xs">
              {notice.details.map((detail) => <p>{detail}</p>)}
            </div>
          ) : null}
        </div>
      </div>
    </div>
  ) : null}

  <section class="grid gap-4 xl:grid-cols-5">
    {cards.map(({ label, value, detail, icon: Icon }) => (
      <article class="rounded-[30px] border border-slate-950/8 bg-white p-5 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{label}</p>
          <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
            <Icon className="size-5" />
          </div>
        </div>
        <p class="mt-5 font-display text-2xl tracking-tight text-slate-950">{value}</p>
        <p class="mt-3 text-sm leading-6 text-slate-600">{detail}</p>
      </article>
    ))}
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Laudos recentes</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Fila pessoal do inspetor</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {overview.summary.pinnedReports} pinados
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {overview.recentReports.length > 0 ? overview.recentReports.map((report) => (
          <a
            href={`/app/inicio?laudo=${report.id}`}
            class:list={[
              "block rounded-[24px] border px-4 py-4 transition",
              report.id === selectedReport?.id
                ? "border-sky-500/25 bg-sky-500/8 shadow-[0_18px_40px_rgba(14,165,233,0.08)]"
                : "border-slate-200 bg-slate-50 hover:border-sky-500/18 hover:bg-white",
            ]}
          >
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="font-semibold text-slate-950">
                  {report.sector}
                  {report.pinned ? (
                    <span class="ml-2 rounded-full bg-sky-500/10 px-2 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
                      Pinado
                    </span>
                  ) : null}
                </p>
                <p class="mt-1 text-sm text-slate-600">
                  {report.template} • revisao {report.reviewStatus} • {report.complianceStatus}
                </p>
              </div>

              <p class="text-sm text-slate-500">{report.updatedAtLabel}</p>
            </div>
          </a>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Nenhum laudo recente foi encontrado para este inspetor.
          </div>
        )}
      </div>
    </article>

    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Resumo operacional</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Primeira leitura do laudo selecionado</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {selectedReport ? `Laudo ${selectedReport.id}` : `Nivel ${overview.profile.accessLevel}`}
        </div>
      </div>

      <div class="mt-6 grid gap-3">
        {selectedReport && selectedSummary ? (
          <>
            <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-950">
                {selectedSummary.laudo_card?.titulo || selectedReport.sector}
              </p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                {selectedSummary.laudo_card?.preview || selectedSummary.resumo.ultima_mensagem_preview || "Sem preview disponível."}
              </p>
              <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                <span class="rounded-full border border-slate-200 px-3 py-2">
                  {selectedSummary.status_visual_label}
                </span>
                <span class="rounded-full border border-slate-200 px-3 py-2">
                  {selectedSummary.laudo_card?.status_card_label || selectedReport.reviewStatus}
                </span>
                <span class="rounded-full border border-slate-200 px-3 py-2">
                  {selectedReport.template}
                </span>
              </div>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Mensagens</p>
                <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">
                  {selectedSummary.resumo.total_mensagens}
                </p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedSummary.resumo.mensagens_nao_lidas} nao lidas • ultima atividade em {selectedSummary.resumo.atualizado_em || "agora"}.
                </p>
              </div>

              <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Pendencias</p>
                <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">
                  {selectedSummary.resumo.pendencias_abertas}
                </p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedSummary.resumo.pendencias_resolvidas} resolvidas • dono atual {selectedSummary.active_owner_role}.
                </p>
              </div>
            </div>

            <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
              <p class="text-sm font-semibold text-slate-950">Acoes de superficie liberadas</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                {selectedSummary.allowed_surface_actions.length > 0
                  ? selectedSummary.allowed_surface_actions.join(", ")
                  : "Nenhuma acao de superficie exposta para este estado."}
              </p>
            </div>
          </>
        ) : selectedReport ? (
          <div class="rounded-[24px] border border-amber-500/18 bg-amber-500/8 p-4 text-amber-950">
            <div class="flex items-start gap-3">
              <div class="rounded-2xl bg-white/80 p-3 text-slate-950">
                <MessageCircleWarning className="size-5" />
              </div>
              <div>
                <p class="text-sm font-semibold">Resumo operacional indisponivel neste momento</p>
                <p class="mt-2 text-sm leading-6">
                  O laudo foi selecionado, mas o backend nao retornou o resumo da mesa nesta leitura.
                </p>
              </div>
            </div>
          </div>
        ) : null}

        <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-950">{overview.profile.email}</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            {overview.profile.phone || "Telefone ainda nao informado."}
          </p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Ultimo login: {overview.profile.lastLoginLabel}
          </p>
          {overview.company.blocked ? (
            <p class="mt-2 text-sm leading-6 text-rose-700">
              Empresa bloqueada: {overview.company.blockedReason || "motivo nao informado."}
            </p>
          ) : (
            <p class="mt-2 text-sm leading-6 text-slate-600">Plano ativo: {overview.company.activePlan}</p>
          )}
        </div>

        <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
          <p class="text-sm font-semibold text-slate-950">O que ja migrou</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Login por senha, cookie httpOnly, primeiro acesso, logout e overview autenticado do inspetor ja rodam no Astro.
          </p>
        </div>

        <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start gap-3">
            <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
              <MessageSquareCode className="size-5" />
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-950">O que continua no Python</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                O chat, a mesa do laudo, pendencias, feed, stream e mutacoes de operacao continuam no backend Python.
              </p>
            </div>
          </div>
        </div>
      </div>
    </article>
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Auditoria</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Eventos recentes do portal</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {overview.summary.auditEvents} eventos
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {overview.recentAudit.length > 0 ? overview.recentAudit.map((entry) => (
          <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="font-semibold text-slate-950">{entry.summary}</p>
                <p class="mt-1 text-sm text-slate-600">
                  {entry.portal} • {entry.action}
                </p>
                {entry.detail ? <p class="mt-2 text-sm leading-6 text-slate-600">{entry.detail}</p> : null}
              </div>

              <p class="text-sm text-slate-500">{entry.createdAtLabel}</p>
            </div>
          </div>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Ainda nao houve eventos recentes do portal do inspetor para este usuario.
          </div>
        )}
      </div>
    </article>

    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Thread recente</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Primeira leitura da conversa da mesa</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {selectedMessages?.tem_mais ? "Com historico" : "Leitura atual"}
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {threadPreview.length > 0 ? threadPreview.map((message) => (
          <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                    {message.message_kind}
                  </span>
                  <span class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                    {message.pendency_state}
                  </span>
                  {message.lida === false ? (
                    <span class="rounded-full bg-amber-500/12 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-amber-800">
                      Nao lida
                    </span>
                  ) : null}
                </div>

                <p class="mt-3 text-sm leading-6 text-slate-700">{message.texto}</p>

                <div class="mt-3 flex flex-wrap gap-3 text-xs text-slate-500">
                  <span>{message.data}</span>
                  {message.resolvida_em_label ? <span>Resolvida em {message.resolvida_em_label}</span> : null}
                  {message.resolvida_por_nome ? <span>Por {message.resolvida_por_nome}</span> : null}
                  {message.anexos && message.anexos.length > 0 ? <span>{message.anexos.length} anexos</span> : null}
                </div>

                {message.message_kind === "mesa_pendency" && selectedReport ? (
                  <form
                    method="POST"
                    action={`/app/inicio/${selectedReport.id}/pendencias/${message.id}`}
                    class="mt-4 flex flex-wrap gap-3"
                  >
                    <input type="hidden" name="returnTo" value={`/app/inicio?laudo=${selectedReport.id}`} />
                    <input type="hidden" name="lida" value={message.pendency_state === "resolved" ? "false" : "true"} />
                    <button
                      type="submit"
                      class:list={[
                        "inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] transition",
                        message.pendency_state === "resolved"
                          ? "border border-slate-200 bg-white text-slate-700 hover:border-slate-300"
                          : "bg-slate-950 text-white hover:bg-slate-800",
                      ]}
                    >
                      {message.pendency_state === "resolved" ? "Reabrir pendencia" : "Marcar resolvida"}
                    </button>
                  </form>
                ) : null}

                {selectedReport ? (
                  <div class="mt-3">
                    <a
                      href={`/app/inicio?laudo=${selectedReport.id}&ref=${message.id}`}
                      class:list={[
                        "inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] transition",
                        referencedMessage?.id === message.id
                          ? "border-sky-500/30 bg-sky-500/10 text-sky-800"
                          : "border-slate-200 bg-white text-slate-700 hover:border-slate-300",
                      ]}
                    >
                      {referencedMessage?.id === message.id ? "Respondendo a esta mensagem" : "Responder a esta mensagem"}
                    </a>
                  </div>
                ) : null}
              </div>

              <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
                <MessageCircle className="size-5" />
              </div>
            </div>
          </div>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Ainda nao ha mensagens disponiveis para o laudo selecionado nesta leitura.
          </div>
        )}

        <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start gap-3">
            <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
              <ScanSearch className="size-5" />
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-950">Proxima fatia natural</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                Com resumo e thread em leitura no Astro, o proximo corte mais util e liberar a primeira acao de pendencia ou reply sobre o laudo selecionado.
              </p>
            </div>
          </div>
        </div>

        {selectedReport ? (
          <form
            method="POST"
            action={`/app/inicio/${selectedReport.id}/responder`}
            class="rounded-[24px] border border-slate-200 bg-slate-50 p-4"
          >
            <input type="hidden" name="returnTo" value={`/app/inicio?laudo=${selectedReport.id}`} />
            <input type="hidden" name="referenciaMensagemId" value={referencedMessage?.id ?? ""} />
            <div class="flex items-start gap-3">
              <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
                <MessageSquareCode className="size-5" />
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-slate-950">Primeira acao: reply textual</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  Esta primeira acao do Astro envia uma resposta simples para a mesa no laudo selecionado, sem anexo.
                </p>

                {referencedMessage ? (
                  <div class="mt-4 rounded-[20px] border border-sky-500/18 bg-sky-500/8 p-4">
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                          Respondendo a mensagem #{referencedMessage.id}
                        </p>
                        <p class="mt-2 text-sm leading-6 text-slate-700">{referencedMessage.texto}</p>
                        <p class="mt-2 text-xs text-slate-500">
                          {referencedMessage.data} • {referencedMessage.message_kind}
                        </p>
                      </div>

                      <a
                        href={`/app/inicio?laudo=${selectedReport.id}`}
                        class="inline-flex items-center gap-2 rounded-full border border-sky-500/20 bg-white px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-sky-800 transition hover:border-sky-500/35"
                      >
                        Limpar
                      </a>
                    </div>
                  </div>
                ) : null}

                <textarea
                  name="texto"
                  rows={4}
                  placeholder="Escreva a resposta operacional para a mesa"
                  class="mt-4 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition placeholder:text-slate-400 focus-visible:ring-2 focus-visible:ring-sky-500"
                />

                <div class="mt-4 flex justify-end">
                  <button
                    type="submit"
