---
import {
  AlertTriangle,
  CheckCircle2,
  Clock3,
  FileStack,
  Fingerprint,
  MessageCircle,
  MessageCircleWarning,
  MessageSquareCode,
  Paperclip,
  ScanSearch,
  Search,
  ShieldCheck,
  Workflow,
} from "lucide-react";

import AppShellLayout from "@/layouts/app-shell-layout.astro";
import { consumeAppNotice } from "@/lib/server/app-notice";
import { getAppWorkspace } from "@/lib/server/app-workspace";

export const prerender = false;

const appSession = Astro.locals.appSession;

if (!appSession) {
  return Astro.redirect("/app/login", 303);
}

const workspace = await getAppWorkspace(appSession, {
  selectedLaudoId: Number(Astro.url.searchParams.get("laudo") ?? 0) || null,
  selectedReferenceMessageId: Number(Astro.url.searchParams.get("ref") ?? 0) || null,
});

if (!workspace) {
  throw new Error("Perfil do portal do inspetor nao encontrado.");
}

const {
  overview,
  inspectorStatus,
  selectedMessages,
  selectedReport,
  selectedSummary,
  threadPreview,
  messageIndex,
  referencedMessage,
} = workspace;
const successMessage = String(Astro.url.searchParams.get("sucesso") ?? "").trim();
const notice = consumeAppNotice(Astro.cookies);
const dateTimeFormatter = new Intl.DateTimeFormat("pt-BR", {
  dateStyle: "short",
  timeStyle: "short",
});

function formatBytes(value: number | undefined) {
  if (!value || value <= 0) {
    return "tamanho nao informado";
  }

  if (value < 1024) {
    return `${value} B`;
  }

  if (value < 1024 * 1024) {
    return `${(value / 1024).toFixed(1)} KB`;
  }

  return `${(value / (1024 * 1024)).toFixed(1)} MB`;
}

const templateOptions = (inspectorStatus?.tipo_template_options ?? []).filter((option) =>
  String(option?.value ?? "").trim() && String(option?.label ?? "").trim(),
);
const templateOptionsByGroup = Array.from(
  templateOptions.reduce((map, option) => {
    const groupLabel = String(option.group_label ?? "Catalogo oficial").trim() || "Catalogo oficial";
    const items = map.get(groupLabel) ?? [];
    items.push(option);
    map.set(groupLabel, items);
    return map;
  }, new Map<string, typeof templateOptions>()),
);
const canCreateInspection = templateOptions.length > 0;
const actionKeySet = new Set((selectedSummary?.allowed_surface_actions ?? []).map((action) => String(action).trim().toLowerCase()));
const canFinalizeInspection = Boolean(
  selectedReport
  && selectedSummary
  && (selectedSummary.permite_edicao || actionKeySet.has("chat_send_to_review") || actionKeySet.has("chat_finalize")),
);
const canReopenInspection = Boolean(
  selectedReport
  && selectedSummary
  && (selectedSummary.permite_reabrir || actionKeySet.has("chat_reopen")),
);

const cards = [
  {
    label: "Portal",
    value: "Inspetor",
    detail: "Sessao oficial emitida no Astro SSR com persistencia em Prisma.",
    icon: Fingerprint,
  },
  {
    label: "Empresa",
    value: overview.company.name,
    detail: overview.profile.email,
    icon: ShieldCheck,
  },
  {
    label: "Laudos do inspetor",
    value: overview.summary.totalReports,
    detail: `${overview.summary.reportsLast30Days} criados nos ultimos 30 dias.`,
    icon: FileStack,
  },
  {
    label: "Ultima atividade",
    value: overview.summary.latestActivityLabel,
    detail: `${overview.summary.activeSessions} sessoes ativas neste portal.`,
    icon: Clock3,
  },
  {
    label: "Expira em",
    value: dateTimeFormatter.format(appSession.session.expiresAt),
    detail: appSession.session.remember ? "Sessao com lembrar ativado." : "Sessao padrao do navegador.",
    icon: Workflow,
  },
];
---

<AppShellLayout
  title="Portal do Inspetor | Tariel Astro"
  description="Home inicial autenticada do inspetor no Astro SSR."
  userName={overview.profile.name}
  companyName={overview.company.name}
  activeItem="dashboard"
>
  <Fragment slot="header">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-600">Portal do inspetor</p>
        <h1 class="mt-3 font-display text-3xl tracking-tight text-slate-950 sm:text-4xl">
          {overview.profile.name}
        </h1>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600">
          Sessao oficial do inspetor ativa no Astro SSR. Esta home agora concentra fila, resumo do caso em foco,
          atalhos operacionais e a entrada para a mesa dedicada sem depender do workspace legado para abrir o fluxo.
        </p>
      </div>

      <div class="rounded-[28px] border border-sky-500/16 bg-sky-500/6 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-700">Status da migracao</p>
        <p class="mt-2 text-lg font-semibold text-slate-950">Home operacional do inspetor em consolidacao</p>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          Entrada, sessao, resumo do caso e atalhos principais ja sairam do legado.
        </p>
      </div>
    </div>
  </Fragment>

  {successMessage ? (
    <div class="mb-6 rounded-[24px] border border-emerald-500/18 bg-emerald-500/8 px-4 py-3 text-sm leading-6 text-emerald-900">
      {successMessage}
    </div>
  ) : null}

  {notice ? (
    <div
      class:list={[
        "mb-6 rounded-[24px] border px-4 py-4 text-sm leading-6",
        notice.tone === "success"
          ? "border-emerald-500/18 bg-emerald-500/8 text-emerald-900"
          : notice.tone === "error"
            ? "border-rose-500/18 bg-rose-500/8 text-rose-900"
            : "border-sky-500/18 bg-sky-500/8 text-sky-950",
      ]}
    >
      <div class="flex items-start gap-3">
        <div class="rounded-2xl bg-white/80 p-2 text-slate-950 shadow-sm">
          {notice.tone === "success" ? <CheckCircle2 className="size-4" /> : <AlertTriangle className="size-4" />}
        </div>
        <div>
          <p class="font-semibold">{notice.title}</p>
          <p class="mt-1">{notice.message}</p>
          {notice.details && notice.details.length > 0 ? (
            <div class="mt-2 space-y-1 text-xs">
              {notice.details.map((detail) => <p>{detail}</p>)}
            </div>
          ) : null}
        </div>
      </div>
    </div>
  ) : null}

  <section class="grid gap-4 xl:grid-cols-5">
    {cards.map(({ label, value, detail, icon: Icon }) => (
      <article class="rounded-[30px] border border-slate-950/8 bg-white p-5 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{label}</p>
          <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
            <Icon className="size-5" />
          </div>
        </div>
        <p class="mt-5 font-display text-2xl tracking-tight text-slate-950">{value}</p>
        <p class="mt-3 text-sm leading-6 text-slate-600">{detail}</p>
      </article>
    ))}
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Laudos recentes</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Fila pessoal do inspetor</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {overview.summary.pinnedReports} pinados
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {overview.recentReports.length > 0 ? overview.recentReports.map((report) => (
          <a
            href={`/app/mesa?laudo=${report.id}`}
            class:list={[
              "block rounded-[24px] border px-4 py-4 transition",
              report.id === selectedReport?.id
                ? "border-sky-500/25 bg-sky-500/8 shadow-[0_18px_40px_rgba(14,165,233,0.08)]"
                : "border-slate-200 bg-slate-50 hover:border-sky-500/18 hover:bg-white",
            ]}
          >
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="font-semibold text-slate-950">
                  {report.sector}
                  {report.pinned ? (
                    <span class="ml-2 rounded-full bg-sky-500/10 px-2 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
                      Pinado
                    </span>
                  ) : null}
                </p>
                <p class="mt-1 text-sm text-slate-600">
                  {report.template} • revisao {report.reviewStatus} • {report.complianceStatus}
                </p>
              </div>

              <div class="text-right">
                <p class="text-sm text-slate-500">{report.updatedAtLabel}</p>
                <span class="mt-2 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
                  Abrir mesa
                </span>
              </div>
            </div>
          </a>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Nenhum laudo recente foi encontrado para este inspetor.
          </div>
        )}
      </div>
    </article>

    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Resumo operacional</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Primeira leitura do laudo selecionado</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {selectedReport ? `Laudo ${selectedReport.id}` : `Nivel ${overview.profile.accessLevel}`}
        </div>
      </div>

      <div class="mt-6 grid gap-3">
        {selectedReport && selectedSummary ? (
          <>
            <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-slate-950">Acoes rapidas do caso</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">
                    A home ja consegue encaminhar o caso em foco sem voltar ao shell antigo.
                  </p>
                </div>
                <div class="flex flex-wrap gap-2">
                  <a
                    href={`/app/mesa?laudo=${selectedReport.id}`}
                    class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-800 transition hover:border-slate-300"
                  >
                    <Search className="size-3.5" />
                    Abrir mesa
                  </a>
                  <a
                    href={`/app/mesa/${selectedReport.id}/preview`}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex items-center gap-2 rounded-full border border-sky-500/24 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-sky-800 transition hover:border-sky-500/40"
                  >
                    <FileStack className="size-3.5" />
                    Preview PDF
                  </a>
                  {canFinalizeInspection ? (
                    <form method="POST" action={`/app/mesa/${selectedReport.id}/finalizar`}>
                      <input type="hidden" name="returnTo" value={`/app/inicio?laudo=${selectedReport.id}`} />
                      <button
                        type="submit"
                        class="inline-flex items-center gap-2 rounded-full border border-emerald-500/24 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-800 transition hover:border-emerald-500/40"
                      >
                        <CheckCircle2 className="size-3.5" />
                        Finalizar
                      </button>
                    </form>
                  ) : null}
                  {canReopenInspection ? (
                    <form method="POST" action={`/app/mesa/${selectedReport.id}/reabrir`}>
                      <input type="hidden" name="returnTo" value={`/app/inicio?laudo=${selectedReport.id}`} />
                      <input type="hidden" name="issuedDocumentPolicy" value="keep_visible" />
                      <button
                        type="submit"
                        class="inline-flex items-center gap-2 rounded-full border border-amber-500/24 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-amber-800 transition hover:border-amber-500/40"
                      >
                        <Clock3 className="size-3.5" />
                        Reabrir
                      </button>
                    </form>
                  ) : null}
                </div>
              </div>
            </div>

            <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-950">
                {selectedSummary.laudo_card?.titulo || selectedReport.sector}
              </p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                {selectedSummary.laudo_card?.preview || selectedSummary.resumo.ultima_mensagem_preview || "Sem preview disponível."}
              </p>
              <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                <span class="rounded-full border border-slate-200 px-3 py-2">
                  {selectedSummary.status_visual_label}
                </span>
                <span class="rounded-full border border-slate-200 px-3 py-2">
                  {selectedSummary.laudo_card?.status_card_label || selectedReport.reviewStatus}
                </span>
                <span class="rounded-full border border-slate-200 px-3 py-2">
                  {selectedReport.template}
                </span>
              </div>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Mensagens</p>
                <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">
                  {selectedSummary.resumo.total_mensagens}
                </p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedSummary.resumo.mensagens_nao_lidas} nao lidas • ultima atividade em {selectedSummary.resumo.atualizado_em || "agora"}.
                </p>
              </div>

              <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Pendencias</p>
                <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">
                  {selectedSummary.resumo.pendencias_abertas}
                </p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedSummary.resumo.pendencias_resolvidas} resolvidas • dono atual {selectedSummary.active_owner_role}.
                </p>
              </div>
            </div>

            <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
              <p class="text-sm font-semibold text-slate-950">Acoes de superficie liberadas</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                {selectedSummary.allowed_surface_actions.length > 0
                  ? selectedSummary.allowed_surface_actions.join(", ")
                  : "Nenhuma acao de superficie exposta para este estado."}
              </p>

              {selectedReport ? (
                <div class="mt-4">
                  <a
                    href={`/app/mesa?laudo=${selectedReport.id}`}
                    class="inline-flex items-center gap-2 rounded-2xl bg-slate-950 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
                  >
                    Abrir mesa dedicada
                  </a>
                </div>
              ) : null}
            </div>
          </>
        ) : selectedReport ? (
          <div class="rounded-[24px] border border-amber-500/18 bg-amber-500/8 p-4 text-amber-950">
            <div class="flex items-start gap-3">
              <div class="rounded-2xl bg-white/80 p-3 text-slate-950">
                <MessageCircleWarning className="size-5" />
              </div>
              <div>
                <p class="text-sm font-semibold">Resumo operacional indisponivel neste momento</p>
                <p class="mt-2 text-sm leading-6">
                  O laudo foi selecionado, mas o backend nao retornou o resumo da mesa nesta leitura.
                </p>
              </div>
            </div>
          </div>
        ) : null}

        <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-950">{overview.profile.email}</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            {overview.profile.phone || "Telefone ainda nao informado."}
          </p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Ultimo login: {overview.profile.lastLoginLabel}
          </p>
          {overview.company.blocked ? (
            <p class="mt-2 text-sm leading-6 text-rose-700">
              Empresa bloqueada: {overview.company.blockedReason || "motivo nao informado."}
            </p>
          ) : (
            <p class="mt-2 text-sm leading-6 text-slate-600">Plano ativo: {overview.company.activePlan}</p>
          )}
        </div>

        <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-slate-950">Nova inspecao pelo Astro</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                A home tambem pode abrir um novo caso usando o catalogo governado do backend oficial.
              </p>
            </div>
            <span class="rounded-full border border-sky-500/20 bg-white px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
              {inspectorStatus?.estado || "sem_relatorio"}
            </span>
          </div>

          <form method="POST" action="/app/mesa/iniciar" class="mt-4 space-y-4">
            <input type="hidden" name="returnTo" value={selectedReport ? `/app/inicio?laudo=${selectedReport.id}` : "/app/inicio"} />

            <label class="block space-y-2">
              <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Modelo tecnico</span>
              <select
                name="tipoTemplate"
                required
                disabled={!canCreateInspection}
                class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-sky-500 disabled:cursor-not-allowed disabled:bg-slate-100"
              >
                <option value="">Selecione um modelo...</option>
                {templateOptionsByGroup.map(([groupLabel, options]) => (
                  <optgroup label={groupLabel}>
                    {options.map((option) => (
                      <option value={option.value}>{option.label}</option>
                    ))}
                  </optgroup>
                ))}
              </select>
            </label>

            <div class="grid gap-3 sm:grid-cols-2">
              <label class="block space-y-2">
                <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Cliente</span>
                <input
                  type="text"
                  name="cliente"
                  maxlength="120"
                  placeholder="Ex: Petrobras"
                  class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-sky-500"
                />
              </label>

              <label class="block space-y-2">
                <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Unidade</span>
                <input
                  type="text"
                  name="unidade"
                  maxlength="120"
                  placeholder="Ex: REPLAN - Paulinia"
                  class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-sky-500"
                />
              </label>
            </div>

            <label class="block space-y-2">
              <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Equipamento</span>
              <input
                type="text"
                name="localInspecao"
                maxlength="160"
                placeholder="Ex: Caldeira B-202"
                class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-sky-500"
              />
            </label>

            {canCreateInspection ? (
              <button
                type="submit"
                class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-500"
              >
                Criar nova inspecao
              </button>
            ) : (
              <div class="rounded-[20px] border border-dashed border-slate-300 bg-white px-4 py-4 text-sm leading-6 text-slate-600">
                O catalogo governado ainda nao expôs modelos de inspeção para este tenant.
              </div>
            )}
          </form>
        </div>

        <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start gap-3">
            <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
              <MessageSquareCode className="size-5" />
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-950">O que continua no Python</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                Regras de dominio, auditoria, feed, preview, PDF e mutacoes de operacao continuam no backend Python.
              </p>
            </div>
          </div>
        </div>
      </div>
    </article>
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Auditoria</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Eventos recentes do portal</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {overview.summary.auditEvents} eventos
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {overview.recentAudit.length > 0 ? overview.recentAudit.map((entry) => (
          <div class="rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="font-semibold text-slate-950">{entry.summary}</p>
                <p class="mt-1 text-sm text-slate-600">
                  {entry.portal} • {entry.action}
                </p>
                {entry.detail ? <p class="mt-2 text-sm leading-6 text-slate-600">{entry.detail}</p> : null}
              </div>

              <p class="text-sm text-slate-500">{entry.createdAtLabel}</p>
            </div>
          </div>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Ainda nao houve eventos recentes do portal do inspetor para este usuario.
          </div>
        )}
      </div>
    </article>

    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Thread recente</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Primeira leitura da conversa da mesa</h2>
        </div>

        <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          {selectedMessages?.tem_mais ? "Com historico" : "Leitura atual"}
        </div>
      </div>

      <div class="mt-6 space-y-3">
        {threadPreview.length > 0 ? threadPreview.map((message) => (
          <div
            id={`mensagem-${message.id}`}
            class:list={[
              "rounded-[24px] border px-4 py-4",
              referencedMessage?.id === message.id
                ? "border-sky-500/30 bg-sky-500/8 shadow-[0_18px_40px_rgba(14,165,233,0.08)]"
                : "border-slate-200 bg-slate-50",
            ]}
          >
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <div class="flex flex-wrap gap-2">
                  {referencedMessage?.id === message.id ? (
                    <span class="rounded-full bg-sky-600 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-white">
                      Mensagem selecionada
                    </span>
                  ) : null}
                  <span class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                    {message.message_kind}
                  </span>
                  <span class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                    {message.pendency_state}
                  </span>
                  {message.lida === false ? (
                    <span class="rounded-full bg-amber-500/12 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-amber-800">
                      Nao lida
                    </span>
                  ) : null}
                </div>

                <p class="mt-3 text-sm leading-6 text-slate-700">{message.texto}</p>

                {message.referencia_mensagem_id ? (
                  <div class="mt-4 rounded-[20px] border border-slate-200 bg-white px-4 py-4">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                          Em resposta a #{message.referencia_mensagem_id}
                        </p>
                        <p class="mt-2 text-sm leading-6 text-slate-700">
                          {messageIndex.get(message.referencia_mensagem_id)?.texto || "A mensagem referenciada nao apareceu nesta leitura recente."}
                        </p>
                        {messageIndex.get(message.referencia_mensagem_id) ? (
                          <p class="mt-2 text-xs text-slate-500">
                            {messageIndex.get(message.referencia_mensagem_id)?.data} • {messageIndex.get(message.referencia_mensagem_id)?.message_kind}
                          </p>
                        ) : null}
                      </div>

                      {messageIndex.get(message.referencia_mensagem_id) ? (
                        <a
                          href={`/app/inicio?laudo=${selectedReport?.id}&ref=${message.referencia_mensagem_id}#mensagem-${message.referencia_mensagem_id}`}
                          class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700 transition hover:border-slate-300 hover:bg-white"
                        >
                          Ver referencia
                        </a>
                      ) : null}
                    </div>
                  </div>
                ) : null}

                <div class="mt-3 flex flex-wrap gap-3 text-xs text-slate-500">
                  <span>{message.data}</span>
                  {message.resolvida_em_label ? <span>Resolvida em {message.resolvida_em_label}</span> : null}
                  {message.resolvida_por_nome ? <span>Por {message.resolvida_por_nome}</span> : null}
                  {message.anexos && message.anexos.length > 0 ? <span>{message.anexos.length} anexos</span> : null}
                </div>

                {message.anexos && message.anexos.length > 0 && selectedReport ? (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {message.anexos.map((attachment) => (
                      <a
                        href={`/app/mesa/${selectedReport.id}/anexos/${attachment.id}`}
                        class="inline-flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50"
                      >
                        <Paperclip className="size-3.5" />
                        {attachment.nome} • {formatBytes(attachment.tamanho_bytes)}
                      </a>
                    ))}
                  </div>
                ) : null}

                {message.message_kind === "mesa_pendency" && selectedReport ? (
                  <form
                    method="POST"
                    action={`/app/mesa/${selectedReport.id}/pendencias/${message.id}`}
                    class="mt-4 flex flex-wrap gap-3"
                  >
                    <input type="hidden" name="returnTo" value={`/app/inicio?laudo=${selectedReport.id}`} />
                    <input type="hidden" name="lida" value={message.pendency_state === "resolved" ? "false" : "true"} />
                    <button
                      type="submit"
                      class:list={[
                        "inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] transition",
                        message.pendency_state === "resolved"
                          ? "border border-slate-200 bg-white text-slate-700 hover:border-slate-300"
                          : "bg-slate-950 text-white hover:bg-slate-800",
                      ]}
                    >
                      {message.pendency_state === "resolved" ? "Reabrir pendencia" : "Marcar resolvida"}
                    </button>
                  </form>
                ) : null}

                {selectedReport ? (
                  <div class="mt-3">
                    <a
                      href={`/app/inicio?laudo=${selectedReport.id}&ref=${message.id}`}
                      class:list={[
                        "inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] transition",
                        referencedMessage?.id === message.id
                          ? "border-sky-500/30 bg-sky-500/10 text-sky-800"
                          : "border-slate-200 bg-white text-slate-700 hover:border-slate-300",
                      ]}
                    >
                      {referencedMessage?.id === message.id ? "Respondendo a esta mensagem" : "Responder a esta mensagem"}
                    </a>
                  </div>
                ) : null}
              </div>

              <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
                <MessageCircle className="size-5" />
              </div>
            </div>
          </div>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Ainda nao ha mensagens disponiveis para o laudo selecionado nesta leitura.
          </div>
        )}

        <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start gap-3">
            <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
              <ScanSearch className="size-5" />
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-950">Proxima fatia natural</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                Com reply referenciado ja liberado no Astro, o proximo ganho estrutural passa a ser ampliar anexos e evoluir a superficie operacional do laudo.
              </p>
            </div>
          </div>
        </div>

        {selectedReport ? (
          <form
            method="POST"
            action={`/app/mesa/${selectedReport.id}/responder`}
            enctype="multipart/form-data"
            class="rounded-[24px] border border-slate-200 bg-slate-50 p-4"
          >
            <input type="hidden" name="returnTo" value={`/app/inicio?laudo=${selectedReport.id}`} />
            <input type="hidden" name="referenciaMensagemId" value={referencedMessage?.id ?? ""} />
            <div class="flex items-start gap-3">
              <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
                <MessageSquareCode className="size-5" />
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-slate-950">Responder a thread do laudo</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  Esta action route compartilhada da mesa envia texto e, quando necessario, um anexo opcional para o laudo selecionado.
                </p>

                {referencedMessage ? (
                  <div class="mt-4 rounded-[20px] border border-sky-500/18 bg-sky-500/8 p-4">
                    <div class="flex items-start justify-between gap-4">
                      <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                          Respondendo a mensagem #{referencedMessage.id}
                        </p>
                        <p class="mt-2 text-sm leading-6 text-slate-700">{referencedMessage.texto}</p>
                        <p class="mt-2 text-xs text-slate-500">
                          {referencedMessage.data} • {referencedMessage.message_kind}
                        </p>
                      </div>

                      <a
                        href={`/app/inicio?laudo=${selectedReport.id}`}
                        class="inline-flex items-center gap-2 rounded-full border border-sky-500/20 bg-white px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-sky-800 transition hover:border-sky-500/35"
                      >
                        Limpar
                      </a>
                    </div>
                  </div>
                ) : null}

                <textarea
                  name="texto"
                  rows={4}
                  placeholder="Escreva a resposta operacional para a mesa"
                  class="mt-4 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition placeholder:text-slate-400 focus-visible:ring-2 focus-visible:ring-sky-500"
                />

                <label class="mt-4 block space-y-2">
                  <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Anexo opcional</span>
                  <input
                    type="file"
                    name="arquivo"
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition file:mr-4 file:rounded-xl file:border-0 file:bg-slate-950 file:px-3 file:py-2 file:text-sm file:font-semibold file:text-white"
                  />
                </label>

                <div class="mt-4 rounded-[20px] border border-slate-200 bg-white px-4 py-4 text-sm leading-6 text-slate-600">
                  O Astro continua apenas como shell autenticado e action route. Validacao, auditoria, persistencia e
                  tratamento do anexo seguem no backend Python.
                </div>

                <div class="mt-4 flex justify-end">
                  <button
                    type="submit"
                    class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(15,23,42,0.18)] transition hover:bg-slate-800"
                  >
                    Enviar resposta
                  </button>
                </div>
              </div>
            </div>
          </form>
        ) : null}
      </div>
    </article>
  </section>
</AppShellLayout>
