---
import {
  AlertTriangle,
  CheckCircle2,
  ClipboardList,
  MessageCircle,
  MessageSquareCode,
  Paperclip,
  ScanSearch,
  Search,
  Send,
  ShieldCheck,
  Workflow,
} from "lucide-react";

import AppShellLayout from "@/layouts/app-shell-layout.astro";
import { consumeAppNotice } from "@/lib/server/app-notice";
import { getAppWorkspace } from "@/lib/server/app-workspace";

export const prerender = false;

const appSession = Astro.locals.appSession;

if (!appSession) {
  return Astro.redirect("/app/login", 303);
}

const searchTerm = String(Astro.url.searchParams.get("q") ?? "").trim().toLowerCase();
const requestedLaudoId = Number(Astro.url.searchParams.get("laudo") ?? 0);
const requestedReferenceMessageId = Number(Astro.url.searchParams.get("ref") ?? 0);
const workspace = await getAppWorkspace(appSession, {
  selectedLaudoId: Number.isInteger(requestedLaudoId) && requestedLaudoId > 0 ? requestedLaudoId : null,
  selectedReferenceMessageId:
    Number.isInteger(requestedReferenceMessageId) && requestedReferenceMessageId > 0
      ? requestedReferenceMessageId
      : null,
});

if (!workspace) {
  throw new Error("Perfil do portal do inspetor nao encontrado.");
}

const { overview, selectedMessages, selectedReport, selectedSummary, threadPreview, messageIndex, referencedMessage } =
  workspace;
const notice = consumeAppNotice(Astro.cookies);
const currentSearch = searchTerm;
const filteredReports = overview.recentReports.filter((report) => {
  if (!currentSearch) {
    return true;
  }

  const haystack = [report.sector, report.template, report.reviewStatus, report.complianceStatus]
    .join(" ")
    .toLowerCase();
  return haystack.includes(currentSearch);
});

const stats = [
  {
    label: "Laudos em foco",
    value: filteredReports.length,
    detail: `${overview.summary.totalReports} laudos visiveis para este inspetor.`,
    icon: ClipboardList,
  },
  {
    label: "Mensagens",
    value: selectedSummary?.resumo.total_mensagens ?? 0,
    detail: `${selectedSummary?.resumo.mensagens_nao_lidas ?? 0} nao lidas no laudo atual.`,
    icon: MessageCircle,
  },
  {
    label: "Pendencias",
    value: selectedSummary?.resumo.pendencias_abertas ?? 0,
    detail: `${selectedSummary?.resumo.pendencias_resolvidas ?? 0} resolvidas no caso atual.`,
    icon: ShieldCheck,
  },
  {
    label: "Estado",
    value: selectedSummary?.status_visual_label ?? "Sem laudo",
    detail: selectedSummary?.laudo_card?.status_card_label || "Nenhum laudo selecionado.",
    icon: Workflow,
  },
] as const;

function buildMesaPath(input: {
  searchTerm?: string;
  selectedLaudoId?: number | null;
  selectedReferenceMessageId?: number | null;
}) {
  const params = new URLSearchParams();
  const nextSearch = String(input.searchTerm ?? currentSearch).trim();
  const nextLaudoId = input.selectedLaudoId ?? null;
  const nextReferenceId = input.selectedReferenceMessageId ?? null;

  if (nextSearch) {
    params.set("q", nextSearch);
  }
  if (nextLaudoId) {
    params.set("laudo", String(nextLaudoId));
  }
  if (nextReferenceId) {
    params.set("ref", String(nextReferenceId));
  }

  const query = params.toString();
  return query ? `/app/mesa?${query}` : "/app/mesa";
}

function queueItemClass(itemId: number) {
  return itemId === selectedReport?.id
    ? "border-sky-400 bg-sky-50 shadow-[0_18px_40px_rgba(14,165,233,0.08)]"
    : "border-slate-200 bg-slate-50 hover:border-slate-300 hover:bg-white";
}

function formatBytes(value: number | undefined) {
  if (!value || value <= 0) {
    return "tamanho nao informado";
  }

  if (value < 1024) {
    return `${value} B`;
  }

  if (value < 1024 * 1024) {
    return `${(value / 1024).toFixed(1)} KB`;
  }

  return `${(value / (1024 * 1024)).toFixed(1)} MB`;
}
---

<AppShellLayout
  title={`Mesa do Inspetor | ${overview.company.name} | Tariel Astro`}
  description="Mesa do inspetor em Astro SSR com fila pessoal, thread e respostas governadas pelo backend Python."
  userName={overview.profile.name}
  companyName={overview.company.name}
  activeItem="mesa"
>
  <Fragment slot="header">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-600">Mesa do inspetor</p>
        <h1 class="mt-3 font-display text-3xl tracking-tight text-slate-950 sm:text-4xl">
          Fila pessoal, thread e resposta no V2
        </h1>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600">
          Esta superficie tira a conversa operacional do laudo de dentro da home e abre a primeira mesa dedicada do
          inspetor no Astro. Policy, auditoria e mutacoes continuam ownership do backend Python.
        </p>
      </div>

      <div class="rounded-[28px] border border-sky-500/16 bg-sky-500/6 px-5 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-700">Estado atual</p>
        <p class="mt-2 text-lg font-semibold text-slate-950">
          {selectedReport ? `Laudo ${selectedReport.id} em foco` : "Nenhum laudo em foco"}
        </p>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          {selectedSummary?.resumo.mensagens_nao_lidas ?? 0} nao lidas, {selectedSummary?.resumo.pendencias_abertas ?? 0}
          {" "}pendencias abertas e reply operacional direto pelo portal novo.
        </p>
      </div>
    </div>
  </Fragment>

  {notice ? (
    <div
      class:list={[
        "mb-6 rounded-[24px] border px-4 py-4 text-sm leading-6",
        notice.tone === "success"
          ? "border-emerald-500/18 bg-emerald-500/8 text-emerald-900"
          : notice.tone === "error"
            ? "border-rose-500/18 bg-rose-500/8 text-rose-900"
            : "border-sky-500/18 bg-sky-500/8 text-sky-950",
      ]}
    >
      <div class="flex items-start gap-3">
        <div class="rounded-2xl bg-white/80 p-2 text-slate-950 shadow-sm">
          {notice.tone === "success" ? <CheckCircle2 className="size-4" /> : <AlertTriangle className="size-4" />}
        </div>
        <div>
          <p class="font-semibold">{notice.title}</p>
          <p class="mt-1">{notice.message}</p>
          {notice.details && notice.details.length > 0 ? (
            <div class="mt-2 space-y-1 text-xs">
              {notice.details.map((detail) => <p>{detail}</p>)}
            </div>
          ) : null}
        </div>
      </div>
    </div>
  ) : null}

  <section class="grid gap-4 xl:grid-cols-4">
    {stats.map(({ label, value, detail, icon: Icon }) => (
      <article class="rounded-[30px] border border-slate-950/8 bg-white p-5 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{label}</p>
          <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
            <Icon className="size-5" />
          </div>
        </div>
        <p class="mt-5 font-display text-3xl tracking-tight text-slate-950">{value}</p>
        <p class="mt-3 text-sm leading-6 text-slate-600">{detail}</p>
      </article>
    ))}
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Fila pessoal</p>
          <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Laudos do inspetor</h2>
        </div>
        <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
          <Search className="size-5" />
        </div>
      </div>

      <form method="GET" action="/app/mesa" class="mt-6 space-y-4">
        <label class="block space-y-2">
          <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Buscar laudo</span>
          <input
            type="text"
            name="q"
            value={currentSearch}
            placeholder="Setor, template ou status"
            class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition focus-visible:ring-2 focus-visible:ring-sky-500"
          />
        </label>

        {selectedReport ? <input type="hidden" name="laudo" value={selectedReport.id} /> : null}

        <button
          type="submit"
          class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
        >
          Filtrar fila
        </button>
      </form>

      <div class="mt-6 space-y-3">
        {filteredReports.length > 0 ? filteredReports.map((report) => (
          <a
            href={buildMesaPath({ selectedLaudoId: report.id, selectedReferenceMessageId: null })}
            class:list={["block rounded-[24px] border px-4 py-4 transition", queueItemClass(report.id)]}
          >
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="font-semibold text-slate-950">
                  {report.sector}
                  {report.pinned ? (
                    <span class="ml-2 rounded-full bg-sky-500/10 px-2 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
                      Pinado
                    </span>
                  ) : null}
                </p>
                <p class="mt-1 text-sm text-slate-600">
                  {report.template} • revisao {report.reviewStatus} • {report.complianceStatus}
                </p>
              </div>

              <p class="text-sm text-slate-500">{report.updatedAtLabel}</p>
            </div>
          </a>
        )) : (
          <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
            Nenhum laudo foi encontrado para este recorte.
          </div>
        )}
      </div>
    </article>

    <div class="space-y-6">
      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Contexto do laudo</p>
            <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Resumo operacional</h2>
          </div>
          <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
            {selectedReport ? `Laudo ${selectedReport.id}` : "Sem selecao"}
          </div>
        </div>

        <div class="mt-6 grid gap-3">
          {selectedReport && selectedSummary ? (
            <>
              <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
                <p class="text-sm font-semibold text-slate-950">
                  {selectedSummary.laudo_card?.titulo || selectedReport.sector}
                </p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedSummary.laudo_card?.preview || selectedSummary.resumo.ultima_mensagem_preview || "Sem preview disponivel."}
                </p>
                <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                  <span class="rounded-full border border-slate-200 px-3 py-2">{selectedSummary.status_visual_label}</span>
                  <span class="rounded-full border border-slate-200 px-3 py-2">
                    {selectedSummary.laudo_card?.status_card_label || selectedReport.reviewStatus}
                  </span>
                  <span class="rounded-full border border-slate-200 px-3 py-2">{selectedReport.template}</span>
                </div>
              </div>

              <div class="grid gap-3 sm:grid-cols-2">
                <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Mensagens</p>
                  <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">{selectedSummary.resumo.total_mensagens}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">
                    {selectedSummary.resumo.mensagens_nao_lidas} nao lidas • ultima atividade em {selectedSummary.resumo.atualizado_em || "agora"}.
                  </p>
                </div>

                <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Pendencias</p>
                  <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">{selectedSummary.resumo.pendencias_abertas}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">
                    {selectedSummary.resumo.pendencias_resolvidas} resolvidas • dono atual {selectedSummary.active_owner_role}.
                  </p>
                </div>
              </div>

              <div class="rounded-[24px] border border-sky-500/16 bg-sky-500/6 p-4">
                <p class="text-sm font-semibold text-slate-950">Acoes de superficie liberadas</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {selectedSummary.allowed_surface_actions.length > 0
                    ? selectedSummary.allowed_surface_actions.join(", ")
                    : "Nenhuma acao de superficie exposta para este estado."}
                </p>
              </div>
            </>
          ) : (
            <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
              Selecione um laudo na fila para abrir a mesa operacional no Astro.
            </div>
          )}
        </div>
      </article>

      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Thread da mesa</p>
            <h2 class="mt-2 font-display text-2xl tracking-tight text-slate-950">Conversa recente do laudo</h2>
          </div>
          <div class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
            {selectedMessages?.tem_mais ? "Com historico" : "Leitura atual"}
          </div>
        </div>

        <div class="mt-6 space-y-3">
          {threadPreview.length > 0 ? threadPreview.map((message) => (
            <div
              id={`mensagem-${message.id}`}
              class:list={[
                "rounded-[24px] border px-4 py-4",
                referencedMessage?.id === message.id
                  ? "border-sky-500/30 bg-sky-500/8 shadow-[0_18px_40px_rgba(14,165,233,0.08)]"
                  : "border-slate-200 bg-slate-50",
              ]}
            >
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <div class="flex flex-wrap gap-2">
                    {referencedMessage?.id === message.id ? (
                      <span class="rounded-full bg-sky-600 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-white">
                        Mensagem selecionada
                      </span>
                    ) : null}
                    <span class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                      {message.message_kind}
                    </span>
                    <span class="rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                      {message.pendency_state}
                    </span>
                    {message.lida === false ? (
                      <span class="rounded-full bg-amber-500/12 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-amber-800">
                        Nao lida
                      </span>
                    ) : null}
                  </div>

                  <p class="mt-3 text-sm leading-6 text-slate-700">{message.texto}</p>

                  {message.referencia_mensagem_id ? (
                    <div class="mt-4 rounded-[20px] border border-slate-200 bg-white px-4 py-4">
                      <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                            Em resposta a #{message.referencia_mensagem_id}
                          </p>
                          <p class="mt-2 text-sm leading-6 text-slate-700">
                            {messageIndex.get(message.referencia_mensagem_id)?.texto || "A mensagem referenciada nao apareceu nesta leitura recente."}
                          </p>
                          {messageIndex.get(message.referencia_mensagem_id) ? (
                            <p class="mt-2 text-xs text-slate-500">
                              {messageIndex.get(message.referencia_mensagem_id)?.data} • {messageIndex.get(message.referencia_mensagem_id)?.message_kind}
                            </p>
                          ) : null}
                        </div>

                        {messageIndex.get(message.referencia_mensagem_id) ? (
                          <a
                            href={buildMesaPath({
                              selectedLaudoId: selectedReport?.id ?? null,
                              selectedReferenceMessageId: message.referencia_mensagem_id,
                            }) + `#mensagem-${message.referencia_mensagem_id}`}
                            class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700 transition hover:border-slate-300 hover:bg-white"
                          >
                            Ver referencia
                          </a>
                        ) : null}
                      </div>
                    </div>
                  ) : null}

                  <div class="mt-3 flex flex-wrap gap-3 text-xs text-slate-500">
                    <span>{message.data}</span>
                    {message.resolvida_em_label ? <span>Resolvida em {message.resolvida_em_label}</span> : null}
                    {message.resolvida_por_nome ? <span>Por {message.resolvida_por_nome}</span> : null}
                    {message.anexos && message.anexos.length > 0 ? <span>{message.anexos.length} anexos</span> : null}
                  </div>

                  {message.anexos && message.anexos.length > 0 && selectedReport ? (
                    <div class="mt-4 flex flex-wrap gap-2">
                      {message.anexos.map((attachment) => (
                        <a
                          href={`/app/mesa/${selectedReport.id}/anexos/${attachment.id}`}
                          class="inline-flex items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50"
                        >
                          <Paperclip className="size-3.5" />
                          {attachment.nome} • {formatBytes(attachment.tamanho_bytes)}
                        </a>
                      ))}
                    </div>
                  ) : null}

                  {message.message_kind === "mesa_pendency" && selectedReport ? (
                    <form
                      method="POST"
                      action={`/app/mesa/${selectedReport.id}/pendencias/${message.id}`}
                      class="mt-4 flex flex-wrap gap-3"
                    >
                      <input type="hidden" name="returnTo" value={buildMesaPath({ selectedLaudoId: selectedReport.id })} />
                      <input type="hidden" name="lida" value={message.pendency_state === "resolved" ? "false" : "true"} />
                      <button
                        type="submit"
                        class:list={[
                          "inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] transition",
                          message.pendency_state === "resolved"
                            ? "border border-slate-200 bg-white text-slate-700 hover:border-slate-300"
                            : "bg-slate-950 text-white hover:bg-slate-800",
                        ]}
                      >
                        {message.pendency_state === "resolved" ? "Reabrir pendencia" : "Marcar resolvida"}
                      </button>
                    </form>
                  ) : null}

                  {selectedReport ? (
                    <div class="mt-3">
                      <a
                        href={buildMesaPath({ selectedLaudoId: selectedReport.id, selectedReferenceMessageId: message.id })}
                        class:list={[
                          "inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] transition",
                          referencedMessage?.id === message.id
                            ? "border-sky-500/30 bg-sky-500/10 text-sky-800"
                            : "border-slate-200 bg-white text-slate-700 hover:border-slate-300",
                        ]}
                      >
                        {referencedMessage?.id === message.id ? "Respondendo a esta mensagem" : "Responder a esta mensagem"}
                      </a>
                    </div>
                  ) : null}
                </div>

                <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
                  <MessageCircle className="size-5" />
                </div>
              </div>
            </div>
          )) : (
            <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
              Ainda nao ha mensagens disponiveis para o laudo selecionado nesta leitura.
            </div>
          )}

          {selectedReport ? (
            <form
              method="POST"
              action={`/app/mesa/${selectedReport.id}/responder`}
              enctype="multipart/form-data"
              class="rounded-[24px] border border-slate-200 bg-slate-50 p-4"
            >
              <input type="hidden" name="returnTo" value={buildMesaPath({ selectedLaudoId: selectedReport.id })} />
              <input type="hidden" name="referenciaMensagemId" value={referencedMessage?.id ?? ""} />
              <div class="flex items-start gap-3">
                <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
                  <MessageSquareCode className="size-5" />
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-semibold text-slate-950">Responder a thread do laudo</p>
                  <p class="mt-2 text-sm leading-6 text-slate-600">
                    A mesa dedicada do inspetor ja permite texto, referencia de mensagem, anexo opcional e toggle de pendencia sem voltar ao template legado.
                  </p>

                  {referencedMessage ? (
                    <div class="mt-4 rounded-[20px] border border-sky-500/18 bg-sky-500/8 p-4">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-800">
                            Respondendo a mensagem #{referencedMessage.id}
                          </p>
                          <p class="mt-2 text-sm leading-6 text-slate-700">{referencedMessage.texto}</p>
                          <p class="mt-2 text-xs text-slate-500">
                            {referencedMessage.data} • {referencedMessage.message_kind}
                          </p>
                        </div>

                        <a
                          href={buildMesaPath({ selectedLaudoId: selectedReport.id, selectedReferenceMessageId: null })}
                          class="inline-flex items-center gap-2 rounded-full border border-sky-500/20 bg-white px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-sky-800 transition hover:border-sky-500/35"
                        >
                          Limpar
                        </a>
                      </div>
                    </div>
                  ) : null}

                  <textarea
                    name="texto"
                    rows={4}
                    placeholder="Escreva a resposta operacional para a mesa"
                    class="mt-4 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition placeholder:text-slate-400 focus-visible:ring-2 focus-visible:ring-sky-500"
                  />

                  <label class="mt-4 block space-y-2">
                    <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Anexo opcional</span>
                    <input
                      type="file"
                      name="arquivo"
                      class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-950 outline-none transition file:mr-4 file:rounded-xl file:border-0 file:bg-slate-950 file:px-3 file:py-2 file:text-sm file:font-semibold file:text-white"
                    />
                  </label>

                  <div class="mt-4 rounded-[20px] border border-slate-200 bg-white px-4 py-4 text-sm leading-6 text-slate-600">
                    O Astro continua apenas como shell autenticado e action route. Validacao, auditoria, persistencia e
                    tratamento do anexo seguem no backend Python.
                  </div>

                  <div class="mt-4 flex justify-end">
                    <button
                      type="submit"
                      class="inline-flex items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(15,23,42,0.18)] transition hover:bg-slate-800"
                    >
                      <Send className="size-4" />
                      Enviar resposta
                    </button>
                  </div>
                </div>
              </div>
            </form>
          ) : (
            <div class="rounded-[24px] border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm leading-6 text-slate-600">
              Selecione um laudo para abrir a thread operacional do inspetor.
            </div>
          )}

          <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-4">
            <div class="flex items-start gap-3">
              <div class="rounded-2xl bg-sky-500/10 p-3 text-sky-700">
                <ScanSearch className="size-5" />
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-950">Proximo passo natural</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  Com a mesa do laudo agora separada da home, o proximo corte estrutural do inspetor pode portar historico,
                  contexto lateral e navegacao do workspace sem continuar inflando <code>/app/inicio</code>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>
</AppShellLayout>
