---
import { ShieldCheck } from "lucide-react";

import AdminNotice from "@/components/app/admin/admin-notice.astro";
import AuthShell from "@/components/app/auth/auth-shell.astro";
import { consumeAdminNotice } from "@/lib/server/admin-notice";

export const prerender = false;

const adminSession = Astro.locals.adminSession;

if (!adminSession) {
  return Astro.redirect("/admin/login", 303);
}

const notice = consumeAdminNotice(Astro.cookies);
---

<AuthShell
  title="Confirmar MFA | Admin-CEO"
  description="Desafio TOTP do Admin-CEO para concluir a sessao administrativa do Tariel V2."
  portalLabel="Admin-CEO"
  heroTitle="A senha ja passou. Agora falta o TOTP para a sessao virar acesso real."
  heroCopy="O portal novo conclui a autenticacao administrativa em duas etapas: credencial local e confirmacao TOTP. Ate o codigo ser validado, o restante do Admin-CEO continua fechado."
  heroItems={[
    "Desafio TOTP executado no Astro SSR sobre a mesma base oficial do painel.",
    "Sessao administrativa so e concluida depois do codigo valido.",
    "A reautenticacao critica reutiliza este mesmo mecanismo de MFA.",
    "Auditoria do login final continua registrada no tenant de plataforma.",
  ]}
  supportText="Canal interno da plataforma"
  submitLabel="Confirmar codigo"
  previewMessage="Fluxo ligado ao backend real do v2."
  variant="admin"
  panelEyebrow="MFA challenge"
  panelTitle="Confirmar o codigo do autenticador"
  panelCopy="Informe o codigo TOTP atual para concluir a sessao administrativa e seguir para o painel novo."
>
  <Fragment slot="form">
    <div class="space-y-5">
      <div class="rounded-[28px] border border-orange-500/15 bg-orange-500/6 p-4 text-orange-950">
        <div class="flex items-start gap-3">
          <div class="rounded-2xl bg-white/80 p-2 text-slate-950 shadow-sm">
            <ShieldCheck className="size-4" />
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em]">Confirmacao obrigatoria</p>
            <p class="mt-2 text-sm leading-6 text-slate-700">
              A conta <strong>{adminSession.user.email}</strong> ja tem TOTP cadastrado. Falta confirmar o codigo atual
              para concluir o acesso.
            </p>
          </div>
        </div>
      </div>

      <AdminNotice notice={notice} />

      <form class="space-y-4" method="POST" action="/admin/mfa/challenge/confirmar" novalidate>
        <label class="block space-y-2">
          <span class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Codigo TOTP</span>
          <input
            type="text"
            name="codigo"
            inputmode="numeric"
            autocomplete="one-time-code"
            minlength="6"
            maxlength="8"
            required
            class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm tracking-[0.24em] text-slate-950 outline-none transition placeholder:text-slate-400 focus-visible:ring-2 focus-visible:ring-orange-500"
            placeholder="000000"
          />
        </label>

        <button
          type="submit"
          class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-[0_18px_40px_rgba(15,23,42,0.18)] transition hover:bg-slate-800"
        >
          Confirmar codigo
        </button>
      </form>
    </div>
  </Fragment>
</AuthShell>
