---
import { ArrowLeft, ArrowUpRight, Building2 } from "lucide-react";

import AdminNotice from "@/components/app/admin/admin-notice.astro";
import StatusPill from "@/components/app/admin/status-pill.astro";
import { consumeAdminNotice } from "@/lib/server/admin-notice";
import AdminShellLayout from "@/layouts/admin-shell-layout.astro";

export const prerender = false;

const notice = consumeAdminNotice(Astro.cookies);
---

<AdminShellLayout title="Novo cliente | Tariel Astro" activeItem="clients" userName="Admin-CEO">
  <Fragment slot="header">
    <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
      <div class="max-w-4xl">
        <a
          href="/admin/clientes"
          class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 transition hover:text-slate-900"
        >
          <ArrowLeft className="size-4" />
          Voltar para empresas
        </a>

        <p class="mt-4 text-xs font-semibold uppercase tracking-[0.28em] text-orange-700">Onboarding migrado</p>
        <h1 class="mt-3 font-display text-4xl tracking-tight text-slate-950 sm:text-5xl">
          Provisionar nova empresa na stack Astro.
        </h1>
        <p class="mt-4 text-sm leading-7 text-slate-600 sm:text-base">
          Este fluxo cria a empresa, provisiona o admin cliente e opcionalmente já sobe os primeiros perfis de campo e análise.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a
          href="/admin/clientes"
          class="inline-flex items-center gap-2 rounded-full border border-slate-950/10 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-950/20 hover:bg-slate-50"
        >
          Ver carteira
          <ArrowUpRight className="size-4" />
        </a>
      </div>
    </div>

    <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-slate-500">
      <StatusPill label="Prisma 7 + Astro SSR" tone="success" />
      <span>Provisionamento direto no PostgreSQL atual</span>
      <span>Credenciais temporárias retornam via flash segura</span>
    </div>
  </Fragment>

  <AdminNotice notice={notice} />

  <form
    method="POST"
    action="/admin/novo-cliente/criar"
    class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]"
  >
    <section class="space-y-6">
      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Empresa</p>
        <h2 class="mt-2 font-display text-3xl tracking-tight text-slate-950">Dados principais do tenant</h2>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <label class="block space-y-2 md:col-span-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Nome da empresa</span>
            <input
              type="text"
              name="nome"
              placeholder="Ex.: Metalúrgica Tariel Nordeste"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">CNPJ</span>
            <input
              type="text"
              name="cnpj"
              inputmode="numeric"
              placeholder="Somente números"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Plano inicial</span>
            <select
              name="plano"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            >
              <option value="Inicial">Inicial</option>
              <option value="Intermediario">Intermediário</option>
              <option value="Ilimitado">Ilimitado</option>
            </select>
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Segmento</span>
            <input
              type="text"
              name="segmento"
              placeholder="Ex.: Siderurgia"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Cidade / Estado</span>
            <input
              type="text"
              name="cidadeEstado"
              placeholder="Ex.: Recife / PE"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2 md:col-span-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Responsável</span>
            <input
              type="text"
              name="nomeResponsavel"
              placeholder="Nome do contato administrativo"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2 md:col-span-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Observações</span>
            <textarea
              name="observacoes"
              rows="4"
              placeholder="Notas de onboarding, condições comerciais ou detalhes de implantação."
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>
        </div>
      </article>

      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Admin cliente</p>
        <h2 class="mt-2 font-display text-3xl tracking-tight text-slate-950">Primeiro acesso obrigatório</h2>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Nome do admin</span>
            <input
              type="text"
              name="adminNome"
              value=""
              disabled
              placeholder="Gerado automaticamente como Administrador {empresa}"
              class="w-full cursor-not-allowed rounded-[24px] border border-slate-200 bg-slate-100 px-4 py-3 text-sm text-slate-500"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">E-mail do admin</span>
            <input
              type="email"
              name="emailAdmin"
              placeholder="admin@empresa.com.br"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>
        </div>
      </article>
    </section>

    <section class="space-y-6">
      <article class="rounded-[32px] border border-slate-950/8 bg-slate-950 p-6 text-white shadow-[0_18px_60px_rgba(15,23,42,0.16)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-orange-200">Provisionamento opcional</p>
        <h2 class="mt-2 font-display text-3xl tracking-tight">Equipe inicial</h2>
        <p class="mt-3 text-sm leading-7 text-slate-300">
          Marque somente os perfis que precisam nascer junto com o tenant. Se deixar em branco, o cliente entra só com o admin.
        </p>
      </article>

      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
        <label class="flex items-center gap-3 text-sm font-medium text-slate-950">
          <input type="checkbox" name="provisionarInspetor" value="1" class="size-4 rounded border-slate-300" />
          Provisionar equipe de campo inicial
        </label>

        <div class="mt-6 grid gap-4">
          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Nome do inspetor</span>
            <input
              type="text"
              name="inspetorNome"
              placeholder="Ex.: João de Campo"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">E-mail do inspetor</span>
            <input
              type="email"
              name="inspetorEmail"
              placeholder="campo@empresa.com.br"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Telefone</span>
            <input
              type="text"
              name="inspetorTelefone"
              placeholder="Ex.: (81) 99999-0000"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>
        </div>
      </article>

      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
        <label class="flex items-center gap-3 text-sm font-medium text-slate-950">
          <input type="checkbox" name="provisionarRevisor" value="1" class="size-4 rounded border-slate-300" />
          Provisionar equipe de análise inicial
        </label>

        <div class="mt-6 grid gap-4">
          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Nome do revisor</span>
            <input
              type="text"
              name="revisorNome"
              placeholder="Ex.: Maria de Análise"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">E-mail do revisor</span>
            <input
              type="email"
              name="revisorEmail"
              placeholder="analise@empresa.com.br"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <div class="grid gap-4 md:grid-cols-2">
            <label class="block space-y-2">
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Telefone</span>
              <input
                type="text"
                name="revisorTelefone"
                placeholder="Ex.: (81) 98888-0000"
                class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
              />
            </label>

            <label class="block space-y-2">
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">CREA</span>
              <input
                type="text"
                name="revisorCrea"
                placeholder="Ex.: CREA 123456"
                class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
              />
            </label>
          </div>
        </div>
      </article>

      <div class="flex flex-wrap gap-3">
        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-full bg-slate-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-800"
        >
          <Building2 className="size-4" />
          Criar cliente
        </button>
        <a
          href="/admin/clientes"
          class="inline-flex items-center gap-2 rounded-full border border-slate-950/10 bg-white px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-950/18 hover:bg-slate-50"
        >
          Cancelar
        </a>
      </div>
    </section>
  </form>
</AdminShellLayout>
