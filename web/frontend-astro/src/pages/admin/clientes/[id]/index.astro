---
import {
  ArrowLeft,
  ArrowUpRight,
  Binary,
  Building2,
  Clock3,
  FileStack,
  KeySquare,
  ShieldCheck,
  Users,
} from "lucide-react";

import AdminNotice from "@/components/app/admin/admin-notice.astro";
import KpiCard from "@/components/app/admin/kpi-card.astro";
import StatusPill from "@/components/app/admin/status-pill.astro";
import { getAdminClientDetail } from "@/lib/server/admin-clients";
import { consumeAdminNotice } from "@/lib/server/admin-notice";
import AdminShellLayout from "@/layouts/admin-shell-layout.astro";

export const prerender = false;

const companyId = Number(Astro.params.id ?? "");
const detail = await getAdminClientDetail(companyId);
const notice = consumeAdminNotice(Astro.cookies);

if (!detail) {
  Astro.response.status = 404;
}

const currencyFormatter = new Intl.NumberFormat("pt-BR", {
  style: "currency",
  currency: "BRL",
});

const dateTimeFormatter = new Intl.DateTimeFormat("pt-BR", {
  dateStyle: "short",
  timeStyle: "short",
});

const detailPath = detail ? `/admin/clientes/${detail.company.id}` : "/admin/clientes";

function formatNumber(value: number) {
  return new Intl.NumberFormat("pt-BR").format(value);
}

function formatCurrency(value: number) {
  return currencyFormatter.format(value);
}

function startCase(value: string) {
  return value
    .split("_")
    .filter(Boolean)
    .map((part) => part.slice(0, 1).toUpperCase() + part.slice(1))
    .join(" ");
}

function reviewTone(status: string) {
  switch (status) {
    case "aprovado":
      return "success";
    case "rejeitado":
      return "danger";
    default:
      return "warning";
  }
}

function complianceTone(status: string) {
  if (status.includes("nao")) {
    return "danger";
  }

  if (status.includes("conforme")) {
    return "success";
  }

  return "info";
}

function catalogStateLabel(state: string) {
  switch (state) {
    case "managed_active":
      return "Catálogo ativo";
    case "managed_empty":
      return "Catálogo vazio";
    default:
      return "Modo legado";
  }
}

function catalogStateTone(state: string) {
  switch (state) {
    case "managed_active":
      return "success";
    case "managed_empty":
      return "warning";
    default:
      return "neutral";
  }
}

function releaseTone(status: string) {
  switch (status) {
    case "active":
      return "success";
    case "paused":
      return "warning";
    case "expired":
      return "danger";
    default:
      return "neutral";
  }
}

function variantStateLabel(variant: {
  isActive: boolean;
  availabilityState: "active" | "blocked" | "available" | "unmapped";
}) {
  if (variant.isActive) {
    return "Ativo";
  }

  switch (variant.availabilityState) {
    case "blocked":
      return "Bloqueado";
    case "available":
      return "Disponível";
    default:
      return "Mapeamento pendente";
  }
}

function variantStateTone(variant: {
  isActive: boolean;
  availabilityState: "active" | "blocked" | "available" | "unmapped";
}) {
  if (variant.isActive) {
    return "success";
  }

  switch (variant.availabilityState) {
    case "blocked":
      return "warning";
    case "available":
      return "info";
    default:
      return "neutral";
  }
}

function releaseTemplateChecked(
  family: {
    tenantRelease: { allowedTemplates: string[] };
    variants: Array<{ isActive: boolean; runtimeTemplateCode: string | null }>;
  },
  templateCode: string,
) {
  if (family.tenantRelease.allowedTemplates.length > 0) {
    return family.tenantRelease.allowedTemplates.includes(templateCode);
  }

  return family.variants.some(
    (variant) => variant.isActive && variant.runtimeTemplateCode === templateCode,
  );
}

function releaseVariantChecked(
  family: {
    tenantRelease: { allowedVariants: string[] };
  },
  variant: { isActive: boolean; selectionToken: string },
) {
  if (family.tenantRelease.allowedVariants.length > 0) {
    return family.tenantRelease.allowedVariants.includes(variant.selectionToken);
  }

  return variant.isActive;
}

const cards = detail
  ? [
      {
        icon: Users,
        label: "Usuários gerenciáveis",
        value: formatNumber(detail.summary.totalUsuarios),
        detail: `${detail.summary.adminsTotal} admins, ${detail.summary.inspetoresTotal} campo e ${detail.summary.revisoresTotal} análise.`,
        tone: "orange" as const,
      },
      {
        icon: Clock3,
        label: "Sessões ativas",
        value: formatNumber(detail.summary.sessoesAtivasTotal),
        detail: `${detail.summary.usuariosComSessaoAtiva} usuários com sessão aberta agora.`,
        tone: "sky" as const,
      },
      {
        icon: FileStack,
        label: "Laudos",
        value: formatNumber(detail.summary.totalLaudos),
        detail: `${detail.summary.templates} templates e ${detail.summary.activeReleases} liberações ativas.`,
        tone: "slate" as const,
      },
      {
        icon: ShieldCheck,
        label: "Custo acumulado",
        value: formatCurrency(detail.summary.custoTotal),
        detail: `${detail.summary.activeSignatories} signatários ativos vinculados ao tenant.`,
        tone: "emerald" as const,
      },
    ]
  : [];
---

{detail ? (
  <AdminShellLayout
    title={`${detail.company.nomeFantasia} | Tariel Astro`}
    activeItem="clients"
    userName="Admin-CEO"
  >
    <Fragment slot="header">
      <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
        <div class="max-w-4xl">
          <a
            href="/admin/clientes"
            class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 transition hover:text-slate-900"
          >
            <ArrowLeft className="size-4" />
            Empresas assinantes
          </a>

          <p class="mt-4 text-xs font-semibold uppercase tracking-[0.28em] text-orange-700">Detalhe migrado</p>
          <h1 class="mt-3 font-display text-4xl tracking-tight text-slate-950 sm:text-5xl">
            {detail.company.nomeFantasia}
          </h1>
          <p class="mt-4 text-sm leading-7 text-slate-600 sm:text-base">
            Empresa #{detail.company.id} • CNPJ {detail.company.cnpj} • Cadastro {dateTimeFormatter.format(detail.company.criadoEm)}
          </p>
        </div>

        <div class="flex flex-wrap gap-2">
          <StatusPill label={detail.status.label} tone={detail.status.tone} />
          <StatusPill label={detail.health.label} tone={detail.health.tone} />
          <a
            href={detail.firstAccess.loginPrefillUrl}
            class="inline-flex items-center gap-2 rounded-full border border-slate-950/10 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-950/18 hover:bg-slate-50"
          >
            Ver entrada do cliente
            <ArrowUpRight className="size-4" />
          </a>
        </div>
      </div>

      <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-slate-500">
        <span>{detail.health.reason}</span>
        <span>Última atividade: {detail.summary.ultimoAcessoLabel}</span>
        <span>Uso atual: {detail.summary.usoLabel}</span>
      </div>
    </Fragment>

    <AdminNotice notice={notice} />

    <section class="grid gap-4 md:grid-cols-2 2xl:grid-cols-4">
      {cards.map((card) => (
        <KpiCard label={card.label} value={card.value} detail={card.detail} icon={card.icon} tone={card.tone} />
      ))}
    </section>

    <section class="mt-8 grid gap-6 xl:grid-cols-3">
      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Bloqueio do tenant</p>
        <h2 class="mt-2 font-display text-3xl tracking-tight text-slate-950">
          {detail.company.statusBloqueio ? "Desbloquear empresa" : "Bloquear empresa"}
        </h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          {detail.company.statusBloqueio
            ? "O tenant já está bloqueado. Ao desbloquear, o acesso volta a obedecer somente as regras normais de login."
            : "Use este fluxo para interromper o acesso inteiro da empresa e invalidar as sessões ativas do tenant."}
        </p>

        <form method="POST" action={`${detailPath}/bloquear`} class="mt-6 space-y-4">
          <input type="hidden" name="returnTo" value={detailPath} />

          {detail.company.statusBloqueio ? (
            <>
              <input type="hidden" name="confirmarDesbloqueio" value="1" />
              <div class="rounded-[24px] border border-slate-950/8 bg-slate-50 p-4 text-sm leading-7 text-slate-600">
                Motivo atual: <strong class="text-slate-950">{detail.company.motivoBloqueio ?? "não informado"}</strong>
              </div>
            </>
          ) : (
            <label class="block space-y-2">
              <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Motivo</span>
              <textarea
                name="motivo"
                rows="4"
                placeholder="Descreva por que a empresa está sendo bloqueada."
                class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
              />
            </label>
          )}

          <button
            type="submit"
            class:list={[
              "inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm font-medium text-white transition",
              detail.company.statusBloqueio ? "bg-emerald-700 hover:bg-emerald-600" : "bg-red-700 hover:bg-red-600",
            ]}
          >
            {detail.company.statusBloqueio ? "Confirmar desbloqueio" : "Bloquear empresa"}
          </button>
        </form>
      </article>

      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Plano contratado</p>
        <h2 class="mt-2 font-display text-3xl tracking-tight text-slate-950">Trocar plano</h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          A atualização reflete direto em limites, leitura de uso e próximas permissões provisionadas no tenant.
        </p>

        <form method="POST" action={`${detailPath}/trocar-plano`} class="mt-6 space-y-4">
          <input type="hidden" name="returnTo" value={detailPath} />

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Plano atual</span>
            <select
              name="plano"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            >
              <option value="Inicial" selected={detail.company.planoAtivo === "Inicial"}>Inicial</option>
              <option value="Intermediario" selected={detail.company.planoAtivo === "Intermediario"}>Intermediário</option>
              <option value="Ilimitado" selected={detail.company.planoAtivo === "Ilimitado"}>Ilimitado</option>
            </select>
          </label>

          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-full bg-slate-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-800"
          >
            Salvar plano
          </button>
        </form>
      </article>

      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Primeiro acesso</p>
        <h2 class="mt-2 font-display text-3xl tracking-tight text-slate-950">Adicionar admin cliente</h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          Cria um novo administrador do tenant com senha temporária e acesso ao portal do cliente.
        </p>

        <form method="POST" action={`${detailPath}/adicionar-admin-cliente`} class="mt-6 space-y-4">
          <input type="hidden" name="returnTo" value={detailPath} />

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Nome</span>
            <input
              type="text"
              name="nome"
              placeholder="Nome completo do administrador"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <label class="block space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">E-mail</span>
            <input
              type="email"
              name="email"
              placeholder="acesso@empresa.com.br"
              class="w-full rounded-[24px] border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 outline-none transition focus:border-slate-950/20 focus:bg-white"
            />
          </label>

          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-full bg-slate-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-800"
          >
            Criar administrador
          </button>
        </form>
      </article>
    </section>

    <section class="mt-8 grid gap-6 xl:grid-cols-[1.12fr_0.88fr]">
      <article class="rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Resumo executivo</p>
        <h2 class="mt-2 font-display text-3xl tracking-tight text-slate-950">Visão administrativa da empresa</h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">
          O detalhe migrado já combina leitura do tenant com os principais comandos de operação do Admin-CEO.
        </p>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="rounded-[26px] border border-slate-950/8 bg-slate-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Primeiro acesso</p>
            <h3 class="mt-3 font-display text-2xl tracking-tight text-slate-950">{detail.firstAccess.statusLabel}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">
              {detail.firstAccess.hasAdmin
                ? `${detail.firstAccess.adminName} • ${detail.firstAccess.adminEmail || "sem e-mail"}`
                : "Nenhum administrador de cliente cadastrado para este tenant."}
            </p>
          </div>

          <div class="rounded-[26px] border border-slate-950/8 bg-slate-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Plano ativo</p>
            <h3 class="mt-3 font-display text-2xl tracking-tight text-slate-950">{detail.company.planoAtivo}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">
              {detail.limits.laudosMes == null ? "Laudos ilimitados" : `${detail.limits.laudosMes} laudos/mês`} •{" "}
              {detail.limits.usuariosMax == null ? "Usuários sem teto" : `${detail.limits.usuariosMax} usuários`}
            </p>
          </div>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="rounded-[26px] border border-slate-950/8 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Perfil da empresa</p>
            <dl class="mt-4 space-y-3 text-sm text-slate-700">
              <div class="flex items-start justify-between gap-4">
                <dt class="text-slate-500">Responsável</dt>
                <dd class="text-right font-medium text-slate-950">{detail.company.nomeResponsavel ?? "Não informado"}</dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-slate-500">Segmento</dt>
                <dd class="text-right font-medium text-slate-950">{detail.company.segmento ?? "Não informado"}</dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-slate-500">Cidade/Estado</dt>
                <dd class="text-right font-medium text-slate-950">{detail.company.cidadeEstado ?? "Não informado"}</dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-slate-500">Observações</dt>
                <dd class="max-w-sm text-right font-medium text-slate-950">{detail.company.observacoes ?? "Sem observações administrativas"}</dd>
              </div>
            </dl>
          </div>

          <div class="rounded-[26px] border border-slate-950/8 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Capacidades do plano</p>
            <div class="mt-4 flex flex-wrap gap-2">
              <StatusPill label={detail.limits.uploadDoc ? "Upload liberado" : "Sem upload"} tone={detail.limits.uploadDoc ? "success" : "neutral"} />
              <StatusPill label={detail.limits.deepResearch ? "Deep research" : "Deep research off"} tone={detail.limits.deepResearch ? "info" : "neutral"} />
              <StatusPill label={detail.company.adminPolicyJson ? "Política admin aplicada" : "Sem política customizada"} tone={detail.company.adminPolicyJson ? "warning" : "neutral"} />
            </div>
            <dl class="mt-4 space-y-3 text-sm text-slate-700">
              <div class="flex items-start justify-between gap-4">
                <dt class="text-slate-500">Integrações máximas</dt>
                <dd class="text-right font-medium text-slate-950">{detail.limits.integracoesMax ?? "Sem teto"}</dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-slate-500">Retenção</dt>
                <dd class="text-right font-medium text-slate-950">{detail.limits.retencaoDias == null ? "Padrão da plataforma" : `${detail.limits.retencaoDias} dias`}</dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-slate-500">Bloqueio vigente</dt>
                <dd class="max-w-sm text-right font-medium text-slate-950">{detail.status.blockedReason ?? "Sem bloqueio vigente"}</dd>
              </div>
            </dl>
          </div>
        </div>
      </article>

      <article class="rounded-[32px] border border-slate-950/8 bg-slate-950 p-6 text-white shadow-[0_18px_60px_rgba(15,23,42,0.16)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-orange-200">Operação atual</p>
        <h2 class="mt-2 font-display text-3xl tracking-tight">Leitura rápida do tenant</h2>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-[26px] border border-white/10 bg-white/5 p-4">
            <p class="text-xs uppercase tracking-[0.22em] text-slate-400">Uso do plano</p>
            <p class="mt-3 font-display text-4xl text-white">{detail.summary.usoPercentual == null ? "Livre" : `${detail.summary.usoPercentual}%`}</p>
          </div>
          <div class="rounded-[26px] border border-white/10 bg-white/5 p-4">
            <p class="text-xs uppercase tracking-[0.22em] text-slate-400">Troca de senha</p>
            <p class="mt-3 font-display text-4xl text-white">{formatNumber(detail.summary.trocaSenhaPendente)}</p>
          </div>
        </div>

        <div class="mt-6 rounded-[28px] border border-white/10 bg-white/5 p-5 text-sm leading-7 text-slate-300">
          <p>
            {detail.summary.usuariosBloqueados > 0
              ? `${detail.summary.usuariosBloqueados} usuários estão bloqueados ou inativos nesta empresa.`
              : "Nenhum usuário bloqueado foi identificado nesta empresa."}
          </p>
          <p class="mt-3">
            {detail.summary.activeReleases > 0
              ? `${detail.summary.activeReleases} liberações de família já estão ativas no catálogo deste tenant.`
              : "Ainda não há liberações ativas de catálogo para este tenant."}
          </p>
        </div>

        <div class="mt-6 grid gap-3 text-sm leading-6 text-slate-300">
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
            Última atividade: <strong class="text-white">{detail.summary.ultimoAcessoLabel}</strong>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
            Custo acumulado de laudos: <strong class="text-white">{formatCurrency(detail.summary.custoTotal)}</strong>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
            Signatários ativos: <strong class="text-white">{formatNumber(detail.summary.activeSignatories)}</strong>
          </div>
        </div>
      </article>
    </section>

    <section class="mt-8 rounded-[32px] border border-slate-950/8 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
      <div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 rounded-full border border-slate-950/10 bg-slate-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600">
            <Binary className="size-4" />
            Catálogo operacional
          </div>
          <h2 class="mt-4 font-display text-3xl tracking-tight text-slate-950">Portfólio de laudos liberados</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            Este bloco controla quais modelos comerciais podem abrir laudos operacionais para a empresa dentro da stack nova.
          </p>
        </div>

        <div class="flex flex-wrap gap-2">
          <StatusPill
            label={catalogStateLabel(detail.catalogPortfolio.catalogState)}
            tone={catalogStateTone(detail.catalogPortfolio.catalogState)}
          />
          <StatusPill
            label={detail.catalogPortfolio.managedByAdminCeo ? "Admin-CEO governa" : "Sem governança ativa"}
            tone={detail.catalogPortfolio.managedByAdminCeo ? "info" : "neutral"}
          />
        </div>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-[26px] border border-slate-950/8 bg-slate-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Modelos ativos</p>
          <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">
            {formatNumber(detail.catalogPortfolio.activeActivationCount)}
          </p>
          <p class="mt-3 text-sm leading-6 text-slate-600">Variantes já liberadas para abrir laudos no tenant.</p>
        </div>

        <div class="rounded-[26px] border border-slate-950/8 bg-slate-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Famílias ativas</p>
          <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">
            {formatNumber(detail.catalogPortfolio.activeFamilyCount)}
          </p>
          <p class="mt-3 text-sm leading-6 text-slate-600">Linhas de serviço que já têm ao menos um modelo habilitado.</p>
        </div>

        <div class="rounded-[26px] border border-slate-950/8 bg-slate-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Modelos publicados</p>
          <p class="mt-3 font-display text-3xl tracking-tight text-slate-950">
            {formatNumber(detail.catalogPortfolio.availableVariantCount)}
          </p>
          <p class="mt-3 text-sm leading-6 text-slate-600">Variantes comerciais disponíveis no catálogo oficial.</p>
