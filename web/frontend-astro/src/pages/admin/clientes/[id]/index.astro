    </Fragment>

    <AdminNotice notice={notice} />

    <section class="rounded-[32px] border border-slate-950/8 bg-white p-8 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
      <div class="max-w-2xl">
        <div class="w-fit rounded-2xl bg-slate-950 p-3 text-orange-300">
          <Building2 className="size-5" />
        </div>
        <h2 class="mt-6 font-display text-3xl tracking-tight text-slate-950">Voltar para a listagem</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Reabra a carteira administrativa e selecione outra empresa para continuar a migração por partes.
        </p>
        <a
          href="/admin/clientes"
          class="mt-6 inline-flex items-center gap-2 rounded-full bg-slate-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-800"
        >
          <KeySquare className="size-4" />
