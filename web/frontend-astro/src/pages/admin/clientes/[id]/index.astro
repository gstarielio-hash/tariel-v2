      </div>
    </section>
  </AdminShellLayout>
) : (
  <AdminShellLayout title="Empresa não encontrada | Tariel Astro" activeItem="clients" userName="Admin-CEO">
    <Fragment slot="header">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-orange-700">Detalhe indisponível</p>
