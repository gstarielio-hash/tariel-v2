---
import { ArrowUpRight, Binary, ShieldCheck, Workflow } from "lucide-react";

import { AuthPreviewForm } from "@/components/app/auth/auth-preview-form";
import StudioLayout from "@/layouts/studio-layout.astro";

interface Props {
  title: string;
  description: string;
  portalLabel: string;
  heroTitle: string;
  heroCopy: string;
  heroItems: string[];
  supportText: string;
  submitLabel?: string;
  previewMessage: string;
  variant?: "portal" | "admin" | "mesa";
}

const {
  title,
  description,
  portalLabel,
  heroTitle,
  heroCopy,
  heroItems,
  supportText,
  submitLabel,
  previewMessage,
  variant = "portal",
} = Astro.props;

const themes = {
  portal: {
    shell: "bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.12),transparent_30%),radial-gradient(circle_at_80%_0%,rgba(14,165,233,0.1),transparent_28%)]",
    hero: "bg-slate-950 text-white",
    badge: "border-sky-400/20 bg-sky-400/10 text-sky-100",
    glow: "bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.35),transparent_32%),radial-gradient(circle_at_85%_10%,rgba(14,165,233,0.25),transparent_25%)]",
  },
  admin: {
    shell: "bg-[radial-gradient(circle_at_top_left,rgba(251,146,60,0.12),transparent_30%),radial-gradient(circle_at_80%_0%,rgba(245,158,11,0.1),transparent_28%)]",
    hero: "bg-slate-950 text-white",
    badge: "border-orange-400/20 bg-orange-400/10 text-orange-100",
    glow: "bg-[radial-gradient(circle_at_top_left,rgba(249,115,22,0.35),transparent_34%),radial-gradient(circle_at_85%_10%,rgba(245,158,11,0.24),transparent_28%)]",
  },
  mesa: {
    shell: "bg-[radial-gradient(circle_at_top_left,rgba(16,185,129,0.12),transparent_30%),radial-gradient(circle_at_80%_0%,rgba(20,184,166,0.1),transparent_28%)]",
    hero: "bg-slate-950 text-white",
    badge: "border-emerald-400/20 bg-emerald-400/10 text-emerald-100",
    glow: "bg-[radial-gradient(circle_at_top_left,rgba(16,185,129,0.35),transparent_34%),radial-gradient(circle_at_85%_10%,rgba(20,184,166,0.24),transparent_28%)]",
  },
} as const;

const theme = themes[variant];

const buildingBlocks = [
  {
    icon: ShieldCheck,
    title: "Shell unico",
    detail: "A mesma base de autenticacao agora cobre os portais sem CSS legado acoplado.",
  },
  {
    icon: Workflow,
    title: "React 19",
    detail: "Interacao local do formulario pronta para acoplar ao fluxo real de login.",
  },
  {
    icon: Binary,
    title: "Pronto para Node",
    detail: "A proxima etapa liga este front ao backend novo com Prisma e rotas server-side.",
  },
];
---

<StudioLayout title={title} description={description}>
  <main class={`relative min-h-screen overflow-hidden ${theme.shell}`}>
    <section class="relative mx-auto flex min-h-screen max-w-7xl items-center px-6 py-10 sm:px-10 lg:px-14">
      <div class="grid w-full overflow-hidden rounded-[36px] border border-slate-950/10 bg-white/72 shadow-[0_24px_120px_rgba(15,23,42,0.12)] backdrop-blur lg:grid-cols-[1.08fr_0.92fr]">
        <div class={`relative overflow-hidden px-8 py-10 sm:px-12 sm:py-14 ${theme.hero}`}>
          <div class={`absolute inset-0 ${theme.glow}`}></div>

          <div class="relative">
            <p class={`inline-flex items-center gap-2 rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] ${theme.badge}`}>
              {portalLabel}
              <ArrowUpRight className="size-4" />
            </p>

            <h1 class="mt-6 max-w-3xl font-display text-4xl leading-[0.96] tracking-tight text-white sm:text-5xl">
              {heroTitle}
            </h1>

            <p class="mt-6 max-w-2xl text-base leading-8 text-slate-300 sm:text-lg">
              {heroCopy}
            </p>

            <div class="mt-10 grid gap-4 md:grid-cols-3">
              {buildingBlocks.map(({ icon: Icon, title: itemTitle, detail }) => (
                <article class="rounded-[28px] border border-white/10 bg-white/6 p-5 backdrop-blur">
                  <div class="flex items-center gap-3">
                    <div class="rounded-2xl bg-white/12 p-3 text-white">
                      <Icon className="size-5" />
                    </div>
                    <h2 class="font-display text-lg text-white">{itemTitle}</h2>
                  </div>
                  <p class="mt-4 text-sm leading-6 text-slate-300">{detail}</p>
                </article>
              ))}
            </div>

            <ul class="mt-8 grid gap-3 text-sm leading-6 text-slate-200 sm:grid-cols-2">
              {heroItems.map((item) => (
                <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">{item}</li>
              ))}
            </ul>
          </div>
        </div>

        <div class="relative px-6 py-8 sm:px-10 sm:py-12">
          <div class="mx-auto max-w-md">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Preview operacional</p>
            <h2 class="mt-3 font-display text-3xl tracking-tight text-slate-950">Autenticacao pronta para receber a integracao real.</h2>
            <p class="mt-4 text-sm leading-7 text-slate-600">
              A prioridade aqui e fechar a migracao de estrutura, layout e componentes primeiro. Depois conectamos sessao,
              CSRF, MFA e provedores de identidade sobre a nova camada Node/TypeScript.
            </p>

            <div class="mt-8 rounded-[30px] border border-slate-950/8 bg-slate-50 p-5">
              <AuthPreviewForm
                client:load
                portalLabel={portalLabel}
                supportText={supportText}
                submitLabel={submitLabel}
                previewMessage={previewMessage}
                variant={variant}
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</StudioLayout>
