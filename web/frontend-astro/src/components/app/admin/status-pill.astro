---
interface Props {
  label: string;
  tone?: "success" | "warning" | "danger" | "info" | "neutral";
}

const { label, tone = "neutral" } = Astro.props;

const tones = {
  success: "border-emerald-500/15 bg-emerald-500/10 text-emerald-800",
  warning: "border-amber-500/15 bg-amber-500/12 text-amber-800",
  danger: "border-red-500/15 bg-red-500/10 text-red-800",
  info: "border-sky-500/15 bg-sky-500/10 text-sky-800",
  neutral: "border-slate-950/10 bg-slate-100 text-slate-700",
} as const;
---

<span class={`inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] ${tones[tone]}`}>
  {label}
</span>
