---
interface Props {
  label: string;
  value: string;
  detail: string;
  icon: any;
  tone?: "slate" | "orange" | "sky" | "emerald";
}

const { label, value, detail, icon: Icon, tone = "slate" } = Astro.props;

const tones = {
  slate: "bg-slate-950 text-white",
  orange: "bg-orange-500 text-white",
  sky: "bg-sky-500 text-white",
  emerald: "bg-emerald-500 text-white",
} as const;
---

<article class="rounded-[30px] border border-slate-950/8 bg-white p-5 shadow-[0_18px_60px_rgba(15,23,42,0.08)]">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">{label}</p>
      <p class="mt-4 font-display text-4xl tracking-tight text-slate-950">{value}</p>
    </div>

    <div class={`rounded-2xl p-3 ${tones[tone]}`}>
      <Icon className="size-5" />
    </div>
  </div>

  <p class="mt-4 text-sm leading-6 text-slate-600">{detail}</p>
</article>
